@model FapWeb.Models.Dtos.ClassManagementDtos.AddStudentToClassDto

@{
    ViewData["Title"] = "Add Student";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">Add Student to @Model.ClassName</h2>
                <a asp-action="Students" asp-route-id="@Model.ClassId" class="btn btn-outline-secondary">Back</a>
            </div>

            <form asp-action="AddStudent" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="ClassId" type="hidden" />
                <input asp-for="ClassName" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="StudentId" class="form-label">Student</label>
                    <select asp-for="StudentId" class="form-select">
                        <option value="">Select student</option>
                        @foreach (var student in Model.StudentOptions)
                        {
                            <option value="@student.Value">@student.Label</option>
                        }
                    </select>
                    <span asp-validation-for="StudentId" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Add Student</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
