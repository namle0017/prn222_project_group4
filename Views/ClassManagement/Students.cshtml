@model FapWeb.Models.Dtos.ClassManagementDtos.ClassStudentsViewDto

@{
    ViewData["Title"] = "Học sinh trong lớp";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">@Model.ClassName - Học sinh</h2>
        <div class="d-flex gap-2">
            <a asp-action="AddStudent" asp-route-classId="@Model.ClassId" class="btn btn-primary">Thêm học sinh</a>
            <a asp-action="Details" asp-route-id="@Model.ClassId" class="btn btn-outline-secondary">Trở về</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (!Model.Students.Any())
    {
        <div class="alert alert-info shadow-sm">Chưa có học sinh nào trong lớp này.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Học sinh</th>
                        <th>Người giám hộ</th>
                        <th>Ngày tham gia</th>
                        <th>Trạng thái</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model.Students)
                    {
                        <tr>
                            <td>@student.StudentName</td>
                            <td>@(string.IsNullOrWhiteSpace(student.GuardianName) ? "Không có" : student.GuardianName)</td>
                            <td>@(student.EnrolledAt.HasValue ? student.EnrolledAt.Value.ToString("dd/MM/yyyy HH:mm") : "Không có")</td>
                            <td><span class="badge @(student.IsActive ? "bg-success" : "bg-secondary")">@(student.IsActive ? "Hoạt động" : "Không hoạt động")</span></td>
                            <td class="text-end">
                                <form asp-action="RemoveStudent" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="classId" value="@Model.ClassId" />
                                    <input type="hidden" name="studentId" value="@student.StudentId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
