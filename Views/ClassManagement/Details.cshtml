@model FapWeb.Models.Dtos.ClassManagementDtos.ClassDetailsDto

@{
    ViewData["Title"] = "Class Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">@Model.ClassName</h2>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.ClassId" class="btn btn-outline-secondary">Edit</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Teacher</div><div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.TeacherName) ? "Unassigned" : Model.TeacherName)</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Students</div><div class="fs-3 fw-semibold">@Model.StudentCount</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Schedules</div><div class="fs-3 fw-semibold">@Model.ScheduleCount</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Status</div><div class="fs-5 fw-semibold">@Model.StatusName</div></div></div></div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Attendance Records</div><div class="fs-3 fw-semibold">@Model.AttendanceRecordsCount</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Expected Tuition</div><div class="fs-3 fw-semibold">@Model.TotalExpectedTuition.ToString("N0") VND</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Outstanding Tuition</div><div class="fs-3 fw-semibold text-danger">@Model.TotalOutstandingTuition.ToString("N0") VND</div></div></div></div>
    </div>

    <div class="d-flex gap-2 flex-wrap mb-4">
        <a asp-action="Students" asp-route-id="@Model.ClassId" class="btn btn-primary">Manage Students</a>
        <a asp-controller="ScheduleManagement" asp-action="Create" asp-route-classId="@Model.ClassId" class="btn btn-outline-primary">Add Schedule</a>
        <a asp-controller="Attendance" asp-action="Take" asp-route-classId="@Model.ClassId" class="btn btn-outline-success">Take Attendance</a>
        <a asp-controller="Tuition" asp-action="Index" class="btn btn-outline-secondary">View Tuition</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Students</h5>
                    @if (!Model.Students.Any())
                    {
                        <div class="alert alert-info mb-0">No students enrolled.</div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var student in Model.Students.Take(5))
                            {
                                <li class="list-group-item px-0 d-flex justify-content-between">
                                    <span>@student.StudentName</span>
                                    <span class="text-muted small">@(student.GuardianName ?? "No guardian")</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Schedules</h5>
                    @if (!Model.Schedules.Any())
                    {
                        <div class="alert alert-warning mb-0">No schedules created yet.</div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var schedule in Model.Schedules.Take(5))
                            {
                                <li class="list-group-item px-0 d-flex justify-content-between">
                                    <span>@schedule.ScheduleDate.ToString("dd/MM/yyyy") @schedule.StartTime - @schedule.EndTime</span>
                                    <span class="text-muted small">@(schedule.Topic ?? "No topic")</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
