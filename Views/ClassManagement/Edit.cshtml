@model FapWeb.Models.Dtos.ClassManagementDtos.ClassFormDto

@{
    ViewData["Title"] = "Edit Class";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">@ViewData["Title"]</h2>
                <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
            </div>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="ClassName" class="form-label"></label>
                        <input asp-for="ClassName" class="form-control" />
                        <span asp-validation-for="ClassName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Teacher</label>
                        <select asp-for="TeacherId" class="form-select">
                            <option value="">Select teacher</option>
                            @foreach (var teacher in Model.TeacherOptions)
                            {
                                <option value="@teacher.Value" selected="@(Model.TeacherId?.ToString() == teacher.Value)">@teacher.Label</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="RoomName" class="form-label"></label>
                        <input asp-for="RoomName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MaxStudents" class="form-label"></label>
                        <input asp-for="MaxStudents" class="form-control" />
                        <span asp-validation-for="MaxStudents" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label"></label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label"></label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TotalSessions" class="form-label"></label>
                        <input asp-for="TotalSessions" class="form-control" />
                        <span asp-validation-for="TotalSessions" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
