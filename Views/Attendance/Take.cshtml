@model FapWeb.Models.Dtos.AttendanceDtos.AttendanceTakeViewModel

@{
    ViewData["Title"] = "Điểm danh";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="mb-1">@ViewData["Title"]</h2>
                    <div class="text-muted">Lớp học: @Model.ClassName</div>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">Trở về</a>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-warning d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span>@Model.ErrorMessage</span>
                    <a asp-controller="ScheduleManagement"
                       asp-action="Create"
                       asp-route-classId="@Model.ClassId"
                       class="btn btn-sm btn-outline-primary">
                        Tạo lịch học
                    </a>
                </div>
            }

            @if (!Model.ScheduleOptions.Any())
            {
                <div class="alert alert-info">Lớp học này chưa có lịch học nào.</div>
            }
            else if (!Model.ScheduleId.HasValue)
            {
                <form asp-action="Take" method="get" class="row g-3 mb-4">
                    <input type="hidden" name="classId" value="@Model.ClassId" />
                    <div class="col-md-4">
                        <label class="form-label">Ngày điểm danh</label>
                        <input type="date"
                               class="form-control"
                               name="attendanceDate"
                               value="@Model.AttendanceDate.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Ca học</label>
                        <select class="form-select" name="scheduleId">
                            <option value="">Chọn ca học</option>
                            @foreach (var option in Model.ScheduleOptions)
                            {
                                <option value="@option.Value">@option.Label</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2 d-grid">
                        <label class="form-label d-none d-md-block">&nbsp;</label>
                        <button type="submit" class="btn btn-primary">Tải ca học</button>
                    </div>
                </form>
            }
            else if (!Model.Students.Any())
            {
                <div class="alert alert-info">Không tìm thấy học sinh nào trong lớp.</div>
            }
            else
            {
                <form asp-action="Take" method="get" class="row g-3 mb-4">
                    <input type="hidden" name="classId" value="@Model.ClassId" />
                    <div class="col-md-4">
                        <label class="form-label">Ngày điểm danh</label>
                        <input type="date"
                               class="form-control"
                               name="attendanceDate"
                               value="@Model.AttendanceDate.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Ca học</label>
                        <select class="form-select" name="scheduleId">
                            @foreach (var option in Model.ScheduleOptions)
                            {
                                <option value="@option.Value" selected="@(Model.ScheduleId?.ToString() == option.Value)">@option.Label</option>
                            }
                        </select>
                        @if (!string.IsNullOrWhiteSpace(Model.ScheduleLabel))
                        {
                            <div class="form-text">Ca học đã chọn: @Model.ScheduleLabel</div>
                        }
                    </div>
                    <div class="col-md-2 d-grid">
                        <label class="form-label d-none d-md-block">&nbsp;</label>
                        <button type="submit" class="btn btn-outline-primary">Đổi ca học</button>
                    </div>
                </form>

                <form asp-action="Take" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ClassId" name="ClassId" />
                    <input type="hidden" asp-for="ScheduleId" name="ScheduleId" />
                    <input type="hidden" name="AttendanceDate" value="@Model.AttendanceDate.ToString("yyyy-MM-dd")" />

                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>Học sinh</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Students.Count; i++)
                                {
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td>
                                            @Model.Students[i].StudentName
                                            <input type="hidden" name="Students[@i].StudentId" value="@Model.Students[i].StudentId" />
                                        </td>
                                        <td>
                                            <div class="d-flex gap-3">
                                                <div class="form-check">
                                                    <input class="form-check-input"
                                                           type="radio"
                                                           name="Students[@i].StatusName"
                                                           value="PRESENT"
                                                           checked="@(Model.Students[i].StatusName != "ABSENT")" />
                                                    <label class="form-check-label">
                                                        <span class="badge bg-success">Có mặt</span>
                                                    </label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input"
                                                           type="radio"
                                                           name="Students[@i].StatusName"
                                                           value="ABSENT"
                                                           checked="@(Model.Students[i].StatusName == "ABSENT")" />
                                                    <label class="form-check-label">
                                                        <span class="badge bg-danger">Vắng mặt</span>
                                                    </label>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <button type="submit" class="btn btn-primary">Lưu điểm danh</button>
                </form>
            }
        </div>
    </div>
</div>
