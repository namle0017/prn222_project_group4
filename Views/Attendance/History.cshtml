@model IEnumerable<FapWeb.Models.Dtos.AttendanceDtos.AttendanceHistoryDto>

@{
    ViewData["Title"] = "Lịch sử điểm danh";
    var history = Model.ToList();
    var total = history.Count;
    var present = history.Count(x => x.StatusName.Equals("PRESENT", StringComparison.OrdinalIgnoreCase));
    var absent = history.Count(x => x.StatusName.Equals("ABSENT", StringComparison.OrdinalIgnoreCase));
    var rate = total == 0 ? 0 : Math.Round((double)present * 100 / total, 2);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">@ViewData["Title"]</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Về trang Điểm danh</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Tổng số buổi</div>
                    <div class="fs-3 fw-semibold">@total</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Có mặt</div>
                    <div class="fs-3 fw-semibold text-success">@present</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Vắng mặt</div>
                    <div class="fs-3 fw-semibold text-danger">@absent</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Tỉ lệ đi học</div>
                    <div class="fs-3 fw-semibold">@rate%</div>
                </div>
            </div>
        </div>
    </div>

    @if (!history.Any())
    {
        <div class="alert alert-info shadow-sm">Không tìm thấy lịch sử điểm danh nào.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Ngày</th>
                        <th>Học sinh</th>
                        <th>Lớp học</th>
                        <th>Trạng thái</th>
                        <th>Giáo viên</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in history)
                    {
                        <tr>
                            <td>@item.AttendanceDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.StudentName</td>
                            <td>@item.ClassName</td>
                            <td>
                                <span class="badge @(item.StatusName.Equals("ABSENT", StringComparison.OrdinalIgnoreCase) ? "bg-danger" : "bg-success")">
                                    @(item.StatusName.Equals("ABSENT", StringComparison.OrdinalIgnoreCase) ? "Vắng mặt" : "Có mặt")
                                </span>
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(item.TeacherName) ? "Không có" : item.TeacherName)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
