@model IEnumerable<FapWeb.Models.Dtos.TuitionDtos.PaymentHistoryDto>

@{
    ViewData["Title"] = "Payment History";
    var payments = Model.ToList();
    var totalAmount = payments.Sum(x => x.Amount);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">@ViewData["Title"]</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Tuition</a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body">
            <div class="text-muted small">Total Payments</div>
            <div class="fs-3 fw-semibold">@totalAmount.ToString("N0") VND</div>
        </div>
    </div>

    @if (!payments.Any())
    {
        <div class="alert alert-info shadow-sm">No payment history found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Student</th>
                        <th>Nội dung</th>
                        <th>Amount</th>
                        <th>Note</th>
                        <th>Recorded By</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in payments)
                    {
                        <tr>
                            <td>@item.PaymentDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.StudentName</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Description) ? "N/A" : item.Description)</td>
                            <td>@item.Amount.ToString("N0") VND</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Note) ? "N/A" : item.Note)</td>
                            <td>@item.RecordedByName</td>
                            <td>
                                <span class="badge bg-secondary">@item.StatusName</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
