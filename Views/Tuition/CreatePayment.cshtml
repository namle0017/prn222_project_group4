@model FapWeb.Models.Dtos.TuitionDtos.PaymentCreateDto

@{
    ViewData["Title"] = "Record Payment";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">@ViewData["Title"]</h2>
                <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
            </div>

            <form asp-action="CreatePayment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="TuitionFeeId" />
                <input type="hidden" asp-for="StudentId" />
                <input type="hidden" asp-for="StudentName" />
                <input type="hidden" asp-for="Description" />
                <input type="hidden" asp-for="RemainingAmount" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label">Student</label>
                    <input class="form-control" value="@Model.StudentName" disabled />
                </div>

                <div class="mb-3">
                    <label class="form-label">Nội dung khoản phí</label>
                    <input class="form-control" value="@(string.IsNullOrWhiteSpace(Model.Description) ? "N/A" : Model.Description)" disabled />
                </div>

                <div class="mb-3">
                    <label class="form-label">Remaining Amount</label>
                    <input class="form-control" value="@Model.RemainingAmount.ToString("N0") VND" disabled />
                </div>

                <div class="mb-3">
                    <label asp-for="Amount" class="form-label"></label>
                    <input asp-for="Amount" class="form-control" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PaymentDate" class="form-label">Payment Date</label>
                    <input asp-for="PaymentDate" type="date" class="form-control" />
                    <span asp-validation-for="PaymentDate" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Note" class="form-label">Note</label>
                    <textarea asp-for="Note" class="form-control" rows="3"></textarea>
                </div>

                <button type="submit" class="btn btn-primary">Submit Payment</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
