@model FapWeb.Models.Dtos.DashboardDtos.TeacherDashboardDto

@{
    ViewData["Title"] = "Teacher Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">@ViewData["Title"]</h2>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">My Classes</div><div class="fs-3 fw-semibold">@Model.MyClasses</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Students</div><div class="fs-3 fw-semibold">@Model.StudentsInMyClasses</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Absent Today</div><div class="fs-3 fw-semibold text-danger">@Model.AbsentStudentsToday</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Need Attendance</div><div class="fs-3 fw-semibold text-warning">@Model.ClassesNeedingAttendance</div></div></div></div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body">
                    <h5 class="card-title">Today's Schedules</h5>
                    @if (!Model.TodaySchedules.Any())
                    {
                        <div class="alert alert-info mb-0">No schedules today.</div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.TodaySchedules)
                            {
                                <li class="list-group-item px-0">@item.ClassName - @item.ScheduleDate.ToString("dd/MM/yyyy") @item.StartTime - @item.EndTime</li>
                            }
                        </ul>
                    }
                </div>
            </div>
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h5 class="card-title">My Classes</h5>
                    @if (!Model.ClassSummaries.Any())
                    {
                        <div class="alert alert-info mb-0">No classes assigned yet.</div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.ClassSummaries)
                            {
                                <li class="list-group-item px-0 d-flex justify-content-between">
                                    <span>@item.ClassName</span>
                                    <span class="text-muted small">@item.StudentCount students</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body">
                    <h5 class="card-title">Upcoming Schedules</h5>
                    @if (!Model.UpcomingSchedules.Any())
                    {
                        <div class="alert alert-info mb-0">No upcoming schedules.</div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.UpcomingSchedules)
                            {
                                <li class="list-group-item px-0">@item.ClassName - @item.ScheduleDate.ToString("dd/MM/yyyy") @item.StartTime - @item.EndTime</li>
                            }
                        </ul>
                    }
                </div>
            </div>
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h5 class="card-title">Latest Notifications</h5>
                    @if (!Model.LatestNotifications.Any())
                    {
                        <div class="alert alert-info mb-0">No notifications yet.</div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.LatestNotifications)
                            {
                                <li class="list-group-item px-0 d-flex justify-content-between">
                                    <span>@item.Title</span>
                                    <span class="text-muted small">@(item.CreatedAt?.ToString("dd/MM HH:mm") ?? "N/A")</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
