@model FapWeb.Models.Dtos.DashboardDtos.TeacherDashboardDto

@{
    ViewData["Title"] = "Teacher Dashboard";
}

<div class="d-flex align-items-center justify-content-between mb-5">
    <div>
        <div class="eyebrow mb-1" style="color:var(--color-lime-text, #7aab15);">// STAFF_PANEL</div>
        <h1 class="heading-xl mb-0">Teacher Dashboard</h1>
        <p class="body-md mt-1 mb-0" style="color:var(--color-text-light-muted);">Quản lý lớp học và điểm danh hôm nay</p>
    </div>
    <div class="badge-live" style="background:rgba(200,240,78,0.1); border-color:rgba(200,240,78,0.3); color:#7aab15;">
        TODAY ACTIVE
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="dashboard-stat-card" style="--accent:#8b7fda; --accent-dim:rgba(139,127,218,0.1);">
            <div class="dsc-icon">🏫</div>
            <div class="dsc-value">@Model.MyClasses</div>
            <div class="dsc-label">My Classes</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="dashboard-stat-card" style="--accent:#c8f04e; --accent-dim:rgba(200,240,78,0.1);">
            <div class="dsc-icon">👨‍🎓</div>
            <div class="dsc-value">@Model.StudentsInMyClasses</div>
            <div class="dsc-label">Students</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="dashboard-stat-card" style="--accent:#ff6eb0; --accent-dim:rgba(255,110,176,0.1);">
            <div class="dsc-icon">⚠️</div>
            <div class="dsc-value" style="color:#ff6eb0 !important;">@Model.AbsentStudentsToday</div>
            <div class="dsc-label">Absent Today</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="dashboard-stat-card" style="--accent:#ffab40; --accent-dim:rgba(255,171,64,0.1);">
            <div class="dsc-icon">📋</div>
            <div class="dsc-value" style="color:#ffab40 !important;">@Model.ClassesNeedingAttendance</div>
            <div class="dsc-label">Need Attendance</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card mb-4">
            <div class="d-flex align-items-center gap-2 mb-4">
                <div style="width:8px; height:8px; border-radius:50%; background:#c8f04e;"></div>
                <h5 class="heading-sm mb-0">Today's Schedules</h5>
            </div>
            @if (!Model.TodaySchedules.Any())
            {
                <div class="alert alert-info mb-0"><i class="bi bi-calendar-x me-2"></i>No schedules today.</div>
            }
            else
            {
                <ul class="list-unstyled mb-0">
                    @foreach (var item in Model.TodaySchedules)
                    {
                        <li class="dashboard-list-item">
                            <span class="dli-icon" style="color:#c8f04e;"><i class="bi bi-clock"></i></span>
                            <span class="dli-label">@item.ClassName</span>
                            <span class="dli-value" style="font-size:12px; font-family:'JetBrains Mono',monospace;">@item.StartTime – @item.EndTime</span>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="card">
            <div class="d-flex align-items-center gap-2 mb-4">
                <div style="width:8px; height:8px; border-radius:50%; background:#8b7fda;"></div>
                <h5 class="heading-sm mb-0">My Classes</h5>
            </div>
            @if (!Model.ClassSummaries.Any())
            {
                <div class="alert alert-info mb-0"><i class="bi bi-building me-2"></i>No classes assigned yet.</div>
            }
            else
            {
                <ul class="list-unstyled mb-0">
                    @foreach (var item in Model.ClassSummaries)
                    {
                        <li class="dashboard-list-item">
                            <span class="dli-icon" style="color:#8b7fda;"><i class="bi bi-building"></i></span>
                            <span class="dli-label">@item.ClassName</span>
                            <span class="dli-value" style="font-size:13px;">@item.StudentCount <span style="font-weight:400; font-size:11px; opacity:0.6;">students</span></span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card mb-4">
            <div class="d-flex align-items-center gap-2 mb-4">
                <div style="width:8px; height:8px; border-radius:50%; background:#4fc3f7;"></div>
                <h5 class="heading-sm mb-0">Upcoming Schedules</h5>
            </div>
            @if (!Model.UpcomingSchedules.Any())
            {
                <div class="alert alert-info mb-0"><i class="bi bi-calendar me-2"></i>No upcoming schedules.</div>
            }
            else
            {
                <ul class="list-unstyled mb-0">
                    @foreach (var item in Model.UpcomingSchedules)
                    {
                        <li class="dashboard-list-item">
                            <span class="dli-icon" style="color:#4fc3f7;"><i class="bi bi-calendar3"></i></span>
                            <span class="dli-label">@item.ClassName</span>
                            <span class="dli-value" style="font-size:12px; font-family:'JetBrains Mono',monospace;">@item.ScheduleDate.ToString("dd/MM") @item.StartTime</span>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="card">
            <div class="d-flex align-items-center gap-2 mb-4">
                <div style="width:8px; height:8px; border-radius:50%; background:#ff6eb0; animation: pulse-glow 2s infinite;"></div>
                <h5 class="heading-sm mb-0">Latest Notifications</h5>
            </div>
            @if (!Model.LatestNotifications.Any())
            {
                <div class="alert alert-info mb-0"><i class="bi bi-bell-slash me-2"></i>No notifications yet.</div>
            }
            else
            {
                <ul class="list-unstyled mb-0">
                    @foreach (var item in Model.LatestNotifications)
                    {
                        <li class="dashboard-list-item">
                            <span class="dli-icon" style="color:#ff6eb0;"><i class="bi bi-bell"></i></span>
                            <span class="dli-label">@item.Title</span>
                            <span class="dli-value" style="font-size:11px; font-family:'JetBrains Mono',monospace;">@(item.CreatedAt?.ToString("dd/MM HH:mm") ?? "N/A")</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>
