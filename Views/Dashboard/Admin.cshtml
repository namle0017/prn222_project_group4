@model FapWeb.Models.Dtos.DashboardDtos.AdminDashboardDto

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">@ViewData["Title"]</h2>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Students</div><div class="fs-3 fw-semibold">@Model.TotalStudents</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Teachers</div><div class="fs-3 fw-semibold">@Model.TotalTeachers</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Parents</div><div class="fs-3 fw-semibold">@Model.TotalParents</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Classes</div><div class="fs-3 fw-semibold">@Model.TotalClasses</div></div></div></div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Expected Tuition</div><div class="fs-5 fw-semibold">@Model.TotalExpectedTuition.ToString("N0") VND</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Collected Tuition</div><div class="fs-5 fw-semibold text-success">@Model.TotalCollectedTuition.ToString("N0") VND</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Outstanding</div><div class="fs-5 fw-semibold text-danger">@Model.TotalOutstandingTuition.ToString("N0") VND</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Attendance Rate</div><div class="fs-3 fw-semibold">@Model.OverallAttendanceRate%</div></div></div></div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h5 class="card-title">System Snapshot</h5>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item px-0">Active schedules: @Model.TotalActiveSchedules</li>
                        <li class="list-group-item px-0">Students with unpaid tuition: @Model.StudentsWithUnpaidTuition</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h5 class="card-title">Latest Notifications</h5>
                    @if (!Model.LatestNotifications.Any())
                    {
                        <div class="alert alert-info mb-0">No notifications yet.</div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.LatestNotifications)
                            {
                                <li class="list-group-item px-0 d-flex justify-content-between">
                                    <span>@item.Title</span>
                                    <span class="text-muted small">@(item.CreatedAt?.ToString("dd/MM HH:mm") ?? "N/A")</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
