@model FapWeb.Models.Dtos.DashboardDtos.ParentDashboardDto

@{
    ViewData["Title"] = "Bảng điều khiển Phụ huynh";
}

<div class="container mt-4">
    <h2 class="mb-4">@ViewData["Title"]</h2>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Con của tôi</div><div class="fs-3 fw-semibold">@Model.MyChildren</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Số buổi vắng</div><div class="fs-3 fw-semibold text-danger">@Model.TotalAbsentCount</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Học phí đã nộp</div><div class="fs-5 fw-semibold text-success">@Model.TotalTuitionPaid.ToString("N0") VND</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0 rounded-4"><div class="card-body"><div class="text-muted small">Học phí còn lại</div><div class="fs-5 fw-semibold text-danger">@Model.TotalTuitionRemaining.ToString("N0") VND</div></div></div></div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h5 class="card-title">Tổng quan các con</h5>
                    @if (!Model.Children.Any())
                    {
                        <div class="alert alert-info mb-0">Chưa có liên kết với con nào.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Học sinh</th>
                                        <th>Lớp học</th>
                                        <th>Tỉ lệ đi học</th>
                                        <th>Học phí còn nợ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Children)
                                    {
                                        <tr>
                                            <td>@item.ChildName</td>
                                            <td>@item.ClassName</td>
                                            <td>@item.AttendanceRate%</td>
                                            <td>@item.RemainingTuition.ToString("N0") VND</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h5 class="card-title">Thông báo mới nhất</h5>
                    @if (!Model.LatestNotifications.Any())
                    {
                        <div class="alert alert-info mb-0">Chưa có thông báo nào.</div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.LatestNotifications)
                            {
                                <li class="list-group-item px-0 d-flex justify-content-between">
                                    <span>@item.Title</span>
                                    <span class="text-muted small">@(item.CreatedAt?.ToString("dd/MM HH:mm") ?? "Không có")</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
