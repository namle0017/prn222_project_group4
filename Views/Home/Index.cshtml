@{
    ViewData["Title"] = "Trang chủ";
    var sessionUserId = Context.Session.GetString("UserId");
    var sessionRoleName = Context.Session.GetString("RoleName");
    var isLoggedIn = !string.IsNullOrWhiteSpace(sessionUserId);
}

<!-- Hero Area with Starfield Background -->
<div class="starfield-hero position-relative py-5 px-4 px-md-5 mb-5 rounded-4 border border-secondary" style="border-color: var(--colors-hairline-violet) !important;">
    
    <!-- Floating Sticker Mascots -->
    <div class="sticker-mascot d-none d-md-block" style="top: 15%; left: 3%; transform: rotate(-8deg);">
        👨‍🚀 FAP_DEB_AGENT
    </div>
    <div class="sticker-mascot lime-outline d-none d-lg-block" style="top: 10px; right: 28%; transform: rotate(4deg);">
        ⚠️ WARNING: ATTENDANCE_ACTIVE
    </div>
    <div class="sticker-mascot d-none d-md-block" style="bottom: 12%; right: 4%; transform: rotate(6deg);">
        👾 BUG_CRUSHER_v8.0
    </div>

    <div class="row align-items-center position-relative py-5" style="z-index: 2;">
        <div class="col-lg-7 text-center text-lg-start">
            <div class="eyebrow text-uppercase mb-3" style="color: var(--colors-accent-pink); font-weight: 600;">
                // OBSERVABILITY FOR EDUCATION
            </div>
            
            <h1 class="display-hero mb-4 text-white">
                HỆ THỐNG QUẢN LÝ <br/>
                <span class="chip-lime-keyword">FAPWEB</span> PORTAL
            </h1>
            
            <p class="body-lg text-white-50 mb-5" style="max-width: 580px;">
                Trang điều hành thông tin học tập và giao dịch chuyên sâu. Giám sát thời gian thực, tự động gửi cảnh báo điểm danh và nợ học phí qua WebSocket SignalR trực tiếp tới phụ huynh.
            </p>
            
            <div class="d-flex gap-3 justify-content-center justify-content-lg-start align-items-center">
                @if (isLoggedIn)
                {
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-inverted btn-lg px-4 py-3">
                        Vào Dashboard <span class="ms-2">→</span>
                    </a>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="btn btn-inverted btn-lg px-4 py-3">
                        Đăng Nhập Ngay
                    </a>
                    <a href="#features" class="btn btn-ghost-on-dark btn-lg px-4 py-3">
                        Khám Phá Tính Năng
                    </a>
                }
            </div>
        </div>
        
        <!-- Tilted Window-Chrome UI Mockup -->
        <div class="col-lg-5 mt-5 mt-lg-0 d-flex justify-content-center">
            <div class="window-chrome tilted-chrome w-100" style="max-width: 460px;">
                <div class="window-chrome-header">
                    <div class="window-chrome-dot red"></div>
                    <div class="window-chrome-dot yellow"></div>
                    <div class="window-chrome-dot green"></div>
                    <span class="ms-2 small text-white-50" style="font-family: var(--font-code); font-size: 11px;">console_output.log</span>
                </div>
                
                <div class="code-block m-0 p-3" style="font-size: 13px; max-height: 250px; overflow-y: auto;">
<span style="color: var(--colors-accent-pink);">[FapWeb System Initialization]</span>
> Initializing Database Context... OK (PostgresSQL)
> Connecting NotificationHub WebSocket... ACTIVE
> Ready for role-based sessions.

<span style="color: var(--colors-accent-lime);">[Live Feed - Class Schedule]</span>
ID: SE1801-PRN222 | Attendance: 98%
Status: <span class="badge bg-success py-1 px-2" style="font-size: 9px;">Checked-in</span>

<span style="color: var(--colors-accent-pink);">[SignalR Alerts Channel]</span>
> Broadcast: Sent warning to Guardian (ID: 9912)
> Message: "Student absent from SE1801 Session 3"
> Delivery latency: 12ms.
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div id="features" class="py-5">
    <div class="text-center mb-5">
        <div class="eyebrow text-uppercase mb-2" style="color: var(--colors-accent-lime);">[ MODULES_OVERVIEW ]</div>
        <h2 class="display-large text-white">6 Phân Hệ Giám Sát Cốt Lõi</h2>
        <p class="body-lg text-white-50" style="max-width: 600px; margin: 0 auto;">Cơ chế kiểm soát chặt chẽ, tối giản hóa thao tác vận hành.</p>
    </div>

    <div class="row g-4">
        <!-- 1. Authentication -->
        <div class="col-md-6 col-lg-4">
            <div class="card-feature-dark d-flex flex-column justify-content-between">
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge bg-success">AUTH_TOKEN</span>
                        <span style="font-family: var(--font-code); color: var(--colors-accent-pink); font-size: 13px;">// 01</span>
                    </div>
                    <h4 class="heading-sm mb-3 text-white">🔐 Xác Thực &amp; Phân Quyền</h4>
                    <p class="body-md text-white-50" style="font-size: 14px;">
                        Cơ chế lưu trữ Session an toàn, kiểm soát truy cập phân lớp cho Admin, Staff (Giáo viên), Phụ huynh và Học sinh.
                    </p>
                </div>
            </div>
        </div>

        <!-- 2. Class Management -->
        <div class="col-md-6 col-lg-4">
            <div class="card-feature-dark d-flex flex-column justify-content-between">
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge bg-warning">CLASS_MGMT</span>
                        <span style="font-family: var(--font-code); color: var(--colors-accent-lime); font-size: 13px;">// 02</span>
                    </div>
                    <h4 class="heading-sm mb-3 text-white">🏫 Quản Lý Lớp Học</h4>
                    <p class="body-md text-white-50" style="font-size: 14px;">
                        Thiết lập sĩ số, điều phối danh sách học sinh và phân bổ giáo viên chủ nhiệm giảng dạy qua giao diện console tối giản.
                    </p>
                </div>
            </div>
        </div>

        <!-- 3. Tuition Management -->
        <div class="col-md-6 col-lg-4">
            <div class="card-feature-dark d-flex flex-column justify-content-between">
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge bg-danger">FINANCE_LEDGER</span>
                        <span style="font-family: var(--font-code); color: var(--colors-accent-pink); font-size: 13px;">// 03</span>
                    </div>
                    <h4 class="heading-sm mb-3 text-white">💳 Kiểm Soát Học Phí</h4>
                    <p class="body-md text-white-50" style="font-size: 14px;">
                        Theo dõi công nợ học kỳ tự động, cập nhật lịch sử hóa đơn tức thì, tính toán số dư chưa thanh toán với độ trễ tối thiểu.
                    </p>
                </div>
            </div>
        </div>

        <!-- 4. Attendance -->
        <div class="col-md-6 col-lg-4">
            <div class="card-feature-dark d-flex flex-column justify-content-between">
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge bg-success">ATTENDANCE</span>
                        <span style="font-family: var(--font-code); color: var(--colors-accent-lime); font-size: 13px;">// 04</span>
                    </div>
                    <h4 class="heading-sm mb-3 text-white">📝 Điểm Danh Chuyên Cần</h4>
                    <p class="body-md text-white-50" style="font-size: 14px;">
                        Giao diện ghi nhận chuyên cần nhanh theo nhóm lớp, thống kê tỉ lệ chuyên cần chính xác qua biểu đồ trực quan.
                    </p>
                </div>
            </div>
        </div>

        <!-- 5. Notifications -->
        <div class="col-md-6 col-lg-4">
            <div class="card-feature-dark d-flex flex-column justify-content-between">
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge bg-warning">SIGNALR_PUSH</span>
                        <span style="font-family: var(--font-code); color: var(--colors-accent-pink); font-size: 13px;">// 05</span>
                    </div>
                    <h4 class="heading-sm mb-3 text-white">🔔 Cảnh Báo WebSocket</h4>
                    <p class="body-md text-white-50" style="font-size: 14px;">
                        Thông báo tự động gửi về điện thoại phụ huynh qua SignalR Hub khi học sinh vắng học hoặc trễ kỳ hạn đóng học phí.
                    </p>
                </div>
            </div>
        </div>

        <!-- 6. Dashboard -->
        <div class="col-md-6 col-lg-4">
            <div class="card-feature-dark d-flex flex-column justify-content-between">
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge bg-danger">METRICS_SYS</span>
                        <span style="font-family: var(--font-code); color: var(--colors-accent-lime); font-size: 13px;">// 06</span>
                    </div>
                    <h4 class="heading-sm mb-3 text-white">📊 Báo Cáo Đa Chiều</h4>
                    <p class="body-md text-white-50" style="font-size: 14px;">
                        Dashboard phân tích chuyên sâu cho ban giám hiệu và học viên. Thống kê kết quả học tập và số dư công nợ toàn hệ thống.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
