<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FapWeb - Hệ thống quản lý học tập và điểm danh thông minh, cảnh báo thời gian thực qua SignalR WebSocket." />
    <title>@ViewData["Title"] - FapWeb</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FapWeb.styles.css" asp-append-version="true" />
</head>
@{
    var sessionUserId = Context.Session.GetString(AppSessionKeys.UserId);
    var sessionRoleName = Context.Session.GetString(AppSessionKeys.RoleName);
    var isLoggedIn = !string.IsNullOrWhiteSpace(sessionUserId);
    var isStaff = AppRoles.IsStaff(sessionRoleName);
    var isAdmin = AppRoles.IsAdmin(sessionRoleName);
    var canViewStudentAreas = AppRoles.IsParent(sessionRoleName) || AppRoles.IsStudent(sessionRoleName);

    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var isHomePage = string.Equals(controller, "Home", StringComparison.OrdinalIgnoreCase) &&
                     string.Equals(action, "Index", StringComparison.OrdinalIgnoreCase);

    var bodyClass = isHomePage ? "canvas-dark" : "canvas-light";
    var navbarClass = isHomePage ? "nav-bar-dark navbar-dark" : "nav-bar-light navbar-light";
    var btnThemeClass = isHomePage ? "btn-inverted" : "btn-primary";
}
<body class="@bodyClass">

    <!-- ⚡ Top Loading Bar -->
    <div id="top-loader" aria-hidden="true">
        <div id="top-loader-bar"></div>
        <div id="top-loader-glow"></div>
    </div>

    <header>
        <nav class="navbar navbar-expand-lg @navbarClass" id="main-navbar">
            <div class="container">
                <!-- Brand -->
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <div class="brand-icon">
                        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="28" height="28" rx="7" fill="url(#brand-grad)"/>
                            <path d="M7 14L11 10L14 13L17 9L21 14" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <circle cx="21" cy="14" r="2.5" fill="#c8f04e"/>
                            <defs>
                                <linearGradient id="brand-grad" x1="0" y1="0" x2="28" y2="28" gradientUnits="userSpaceOnUse">
                                    <stop stop-color="#5b46c1"/>
                                    <stop offset="1" stop-color="#8b7fda"/>
                                </linearGradient>
                            </defs>
                        </svg>
                    </div>
                    <span>FAPWEB</span>
                </a>

                <!-- Toggler -->
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Nav Links -->
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav flex-grow-1 ms-4 gap-1">
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-1" asp-area="" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-grid-1x2" style="font-size:13px;"></i> Dashboard
                            </a>
                        </li>
                        @if (isLoggedIn)
                        {
                            @if (isStaff)
                            {
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="ClassManagement" asp-action="Index">
                                        <i class="bi bi-building" style="font-size:13px;"></i> Classes
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="ScheduleManagement" asp-action="Index">
                                        <i class="bi bi-calendar3" style="font-size:13px;"></i> Schedule
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Attendance" asp-action="Index">
                                        <i class="bi bi-check2-square" style="font-size:13px;"></i> Attendance
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Tuition" asp-action="Index">
                                        <i class="bi bi-credit-card" style="font-size:13px;"></i> Tuition
                                    </a>
                                </li>
                            }

                            @if (isAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Transaction" asp-action="Index">
                                        <i class="bi bi-arrow-left-right" style="font-size:13px;"></i> Transactions
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="User" asp-action="Index">
                                        <i class="bi bi-people" style="font-size:13px;"></i> Users
                                    </a>
                                </li>
                            }

                            @if (canViewStudentAreas || isStaff)
                            {
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Notification" asp-action="Index">
                                        <i class="bi bi-bell" style="font-size:13px;"></i> Notifications
                                    </a>
                                </li>
                            }

                            @if (canViewStudentAreas)
                            {
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Attendance" asp-action="History">
                                        <i class="bi bi-clock-history" style="font-size:13px;"></i> Attendance History
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Tuition" asp-action="History">
                                        <i class="bi bi-receipt" style="font-size:13px;"></i> Payment History
                                    </a>
                                </li>
                            }

                            @if (!AppRoles.IsStaff(sessionRoleName))
                            {
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Transaction" asp-action="MyHistory">
                                        <i class="bi bi-wallet2" style="font-size:13px;"></i> My Transactions
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <!-- Auth Actions -->
                    <div class="d-flex align-items-center gap-2 ms-auto">
                        @if (isLoggedIn)
                        {
                            <!-- Role pill -->
                            <div class="role-pill">
                                <i class="bi bi-person-circle"></i>
                                <span>@sessionRoleName</span>
                            </div>
                            <a class="btn btn-sm btn-ghost-on-dark" style="padding:7px 14px; font-size:13px;" asp-controller="Auth" asp-action="ChangePassword">
                                <i class="bi bi-key me-1"></i>Password
                            </a>
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm" style="padding:7px 14px; font-size:13px; background:rgba(255,110,176,0.12); color:#ff6eb0; border:1px solid rgba(255,110,176,0.3); border-radius:10px;">
                                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                                </button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-sm @btnThemeClass" style="padding:8px 20px; font-size:14px;" asp-controller="Auth" asp-action="Login">
                                <i class="bi bi-lightning-charge-fill me-1"></i>Đăng nhập
                            </a>
                        }

                        <!-- Theme Toggle Button -->
                        <button id="theme-toggle-btn" title="Chuyển đổi giao diện" aria-label="Toggle theme">
                            <i class="bi bi-moon-stars-fill" id="theme-icon"></i>
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container py-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <!-- Squiggly Divider -->
    <div class="container-fluid px-0">
        <svg class="squiggly-divider" viewBox="0 0 1440 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 14C80 14 160 4 240 4C320 4 400 24 480 24C560 24 640 4 720 4C800 4 880 24 960 24C1040 24 1120 4 1200 4C1280 4 1360 14 1440 14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4 text-center text-md-start mb-3 mb-md-0">
                    <a asp-controller="Home" asp-action="Index" class="d-inline-flex align-items-center gap-2 text-decoration-none" style="opacity:0.7;">
                        <svg width="20" height="20" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="28" height="28" rx="7" fill="url(#footer-grad)"/>
                            <path d="M7 14L11 10L14 13L17 9L21 14" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <circle cx="21" cy="14" r="2.5" fill="#c8f04e"/>
                            <defs>
                                <linearGradient id="footer-grad" x1="0" y1="0" x2="28" y2="28" gradientUnits="userSpaceOnUse">
                                    <stop stop-color="#5b46c1"/>
                                    <stop offset="1" stop-color="#8b7fda"/>
                                </linearGradient>
                            </defs>
                        </svg>
                        <span style="font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:15px;">FAPWEB</span>
                    </a>
                    <p class="mt-2 mb-0" style="font-size:12px; opacity:0.5;">&copy; 2026 FapWeb. All rights reserved.</p>
                </div>
                <div class="col-md-4 text-center mb-3 mb-md-0">
                    <div class="badge-live mx-auto" style="width:fit-content;">
                        SYSTEM ONLINE
                    </div>
                </div>
                <div class="col-md-4 text-center text-md-end">
                    <span style="font-family:'JetBrains Mono',monospace; font-size:11px; opacity:0.4;">
                        SignalR · PostgreSQL · ASP.NET Core
                    </span>
                </div>
            </div>
        </div>
    </footer>

    <!-- ⬆️ Back-to-top Button -->
    <button id="back-to-top" aria-label="Cuộn về đầu trang" title="Lên đầu trang">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M9 14V4M9 4L4.5 8.5M9 4L13.5 8.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </button>

    <!-- 🔔 Global Toast Container -->
    <div id="fap-toast-container" aria-live="polite" aria-atomic="false"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ── Scroll Reveal ────────────────────────────────────
        const reveals = document.querySelectorAll('.reveal');
        const revObs = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.classList.add('visible');
                    revObs.unobserve(e.target);
                }
            });
        }, { threshold: 0.12 });
        reveals.forEach(el => revObs.observe(el));

        // ── Navbar scroll shadow ─────────────────────────────
        const navbar = document.getElementById('main-navbar');
        if (navbar) {
            window.addEventListener('scroll', () => {
                navbar.style.boxShadow = window.scrollY > 20
                    ? '0 4px 30px rgba(0,0,0,0.4)'
                    : '';
            }, { passive: true });
        }

        // ── TOP LOADING BAR ──────────────────────────────────
        const Loader = {
            bar: document.getElementById('top-loader-bar'),
            wrap: document.getElementById('top-loader'),
            glow: document.getElementById('top-loader-glow'),
            timer: null,
            pct: 0,

            start() {
                this.pct = 0;
                this.wrap.style.opacity = '1';
                this.set(20);
                clearInterval(this.timer);
                this.timer = setInterval(() => {
                    if (this.pct < 85) this.set(this.pct + Math.random() * 8);
                }, 400);
            },

            set(p) {
                this.pct = Math.min(p, 99);
                this.bar.style.width = this.pct + '%';
                this.glow.style.left = this.pct + '%';
            },

            done() {
                clearInterval(this.timer);
                this.set(100);
                setTimeout(() => {
                    this.wrap.style.opacity = '0';
                    setTimeout(() => this.bar.style.width = '0', 400);
                }, 250);
            }
        };

        // Trigger on all internal link clicks
        document.addEventListener('click', function(e) {
            const a = e.target.closest('a[href]');
            if (!a) return;
            const href = a.getAttribute('href');
            if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('javascript:')) return;
            if (a.target === '_blank') return;
            try {
                const url = new URL(href, location.href);
                if (url.origin !== location.origin) return;
            } catch { return; }
            Loader.start();
        });

        // Trigger on form submits
        document.addEventListener('submit', function() {
            Loader.start();
        });

        // Complete when page finishes loading
        window.addEventListener('load', () => Loader.done());
        document.addEventListener('DOMContentLoaded', () => {
            // Immediate page load done signal
            if (document.readyState === 'complete') Loader.done();
        });

        // ── DARK / LIGHT MODE TOGGLE ─────────────────────────
        const ThemeToggle = {
            btn: document.getElementById('theme-toggle-btn'),
            icon: document.getElementById('theme-icon'),
            body: document.body,
            navbar: document.getElementById('main-navbar'),

            // Detect current mode from body class
            isDark() {
                return this.body.classList.contains('canvas-dark');
            },

            // Get saved preference; undefined = follow current server-rendered class
            getSaved() {
                return localStorage.getItem('fap-theme');
            },

            applyTheme(dark) {
                if (dark) {
                    this.body.classList.remove('canvas-light');
                    this.body.classList.add('canvas-dark');
                    if (this.navbar) {
                        this.navbar.classList.remove('nav-bar-light', 'navbar-light');
                        this.navbar.classList.add('nav-bar-dark', 'navbar-dark');
                    }
                    this.icon.className = 'bi bi-sun-fill';
                    this.btn.title = 'Chuyển sang sáng';
                } else {
                    this.body.classList.remove('canvas-dark');
                    this.body.classList.add('canvas-light');
                    if (this.navbar) {
                        this.navbar.classList.remove('nav-bar-dark', 'navbar-dark');
                        this.navbar.classList.add('nav-bar-light', 'navbar-light');
                    }
                    this.icon.className = 'bi bi-moon-stars-fill';
                    this.btn.title = 'Chuyển sang tối';
                }
            },

            init() {
                if (!this.btn) return;
                const saved = this.getSaved();
                if (saved) {
                    this.applyTheme(saved === 'dark');
                } else {
                    // Sync icon with server-rendered class
                    this.icon.className = this.isDark() ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
                    this.btn.title = this.isDark() ? 'Chuyển sang sáng' : 'Chuyển sang tối';
                }

                this.btn.addEventListener('click', () => {
                    const nowDark = !this.isDark();
                    this.applyTheme(nowDark);
                    localStorage.setItem('fap-theme', nowDark ? 'dark' : 'light');
                });
            }
        };

        ThemeToggle.init();

        // ── BACK TO TOP ──────────────────────────────────────
        (function () {
            const btn = document.getElementById('back-to-top');
            if (!btn) return;

            // Show/hide based on scroll position
            window.addEventListener('scroll', function () {
                if (window.scrollY > 320) {
                    btn.classList.add('btt-visible');
                } else {
                    btn.classList.remove('btt-visible');
                }
            }, { passive: true });

            // Smooth scroll to top on click
            btn.addEventListener('click', function () {
                window.scrollTo({ top: 0, behavior: 'smooth' });
                // Bounce animation
                btn.classList.add('btt-bounce');
                setTimeout(() => btn.classList.remove('btt-bounce'), 500);
            });
        })();

        // ── GLOBAL TOAST SYSTEM ──────────────────────────────
        /**
         * FapToast — global toast notification system
         * Usage:
         *   FapToast.show('Message text')                      // default (info)
         *   FapToast.show('Success!', 'success')
         *   FapToast.show('Warning!', 'warning')
         *   FapToast.show('Error!', 'error')
         *   FapToast.show('Custom msg', 'info', 4000)          // custom duration ms
         */
        window.FapToast = (function () {
            const container = document.getElementById('fap-toast-container');
            let counter = 0;

            const ICONS = {
                success: '<i class="bi bi-check-circle-fill"></i>',
                warning: '<i class="bi bi-exclamation-triangle-fill"></i>',
                error:   '<i class="bi bi-x-circle-fill"></i>',
                info:    '<i class="bi bi-info-circle-fill"></i>'
            };

            const COLORS = {
                success: { border: 'rgba(200,240,78,0.35)',  icon: '#c8f04e', bar: '#c8f04e' },
                warning: { border: 'rgba(255,171,64,0.35)', icon: '#ffab40', bar: '#ffab40' },
                error:   { border: 'rgba(255,110,176,0.4)', icon: '#ff6eb0', bar: '#ff6eb0' },
                info:    { border: 'rgba(139,127,218,0.4)', icon: '#8b7fda', bar: '#8b7fda' }
            };

            function show(message, type, duration) {
                type     = type     || 'info';
                duration = duration || 4000;
                const id = 'fap-toast-' + (++counter);
                const c  = COLORS[type] || COLORS.info;

                const el = document.createElement('div');
                el.className = 'fap-toast fap-toast--' + type;
                el.id = id;
                el.setAttribute('role', 'alert');
                el.innerHTML =
                    '<div class="fap-toast__icon" style="color:' + c.icon + '">' + (ICONS[type] || ICONS.info) + '</div>' +
                    '<div class="fap-toast__body">' +
                        '<p class="fap-toast__msg">' + message + '</p>' +
                        '<div class="fap-toast__progress"><div class="fap-toast__bar" style="background:' + c.bar + '; animation-duration:' + duration + 'ms"></div></div>' +
                    '</div>' +
                    '<button class="fap-toast__close" onclick="FapToast.dismiss(\'' + id + '\')" aria-label="Đóng">' +
                        '<i class="bi bi-x"></i>' +
                    '</button>';

                el.style.borderColor = c.border;
                container.appendChild(el);

                // Trigger enter animation
                requestAnimationFrame(() => {
                    requestAnimationFrame(() => el.classList.add('fap-toast--show'));
                });

                // Auto dismiss
                const timer = setTimeout(() => dismiss(id), duration);
                el._timer = timer;

                // Pause on hover
                el.addEventListener('mouseenter', () => clearTimeout(el._timer));
                el.addEventListener('mouseleave', () => {
                    el._timer = setTimeout(() => dismiss(id), 1500);
                });

                return id;
            }

            function dismiss(id) {
                const el = document.getElementById(id);
                if (!el) return;
                clearTimeout(el._timer);
                el.classList.remove('fap-toast--show');
                el.classList.add('fap-toast--hide');
                setTimeout(() => el.remove(), 400);
            }

            return { show: show, dismiss: dismiss };
        })();

        // ── Auto-convert ASP.NET TempData alerts to Toasts ───
        document.querySelectorAll('.alert-success[data-toast]').forEach(function (el) {
            FapToast.show(el.textContent.trim(), 'success');
            el.remove();
        });
        document.querySelectorAll('.alert-danger[data-toast]').forEach(function (el) {
            FapToast.show(el.textContent.trim(), 'error');
            el.remove();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <style>
        /* ── Top Loading Bar ─────────────────────── */
        #top-loader {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: 3px;
            z-index: 9999;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        #top-loader-bar {
            position: absolute;
            top: 0; left: 0;
            height: 100%;
            width: 0;
            background: linear-gradient(90deg, #5b46c1, #c8f04e, #ff6eb0);
            border-radius: 0 3px 3px 0;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
            box-shadow: 0 0 12px rgba(200, 240, 78, 0.6);
        }
        #top-loader-glow {
            position: absolute;
            top: -2px;
            width: 80px;
            height: 7px;
            border-radius: 50%;
            background: rgba(200, 240, 78, 0.7);
            filter: blur(6px);
            transform: translateX(-50%);
            transition: left 0.3s ease;
        }

        /* ── Theme Toggle Button ─────────────────── */
        #theme-toggle-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1px solid rgba(139, 127, 218, 0.28);
            background: rgba(139, 127, 218, 0.1);
            color: #8b7fda;
            cursor: pointer;
            font-size: 15px;
            transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
            flex-shrink: 0;
        }
        #theme-toggle-btn:hover {
            background: rgba(139, 127, 218, 0.2);
            border-color: rgba(139, 127, 218, 0.5);
            transform: rotate(20deg) scale(1.08);
            color: #c8f04e;
        }
        body.canvas-light #theme-toggle-btn {
            background: rgba(91, 70, 193, 0.06);
            border-color: rgba(91, 70, 193, 0.18);
            color: #5b46c1;
        }
        body.canvas-light #theme-toggle-btn:hover {
            background: rgba(91, 70, 193, 0.12);
        }

        /* ── Brand icon ─────────────────────────── */
        .brand-icon {
            transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .navbar-brand:hover .brand-icon {
            transform: rotate(-8deg) scale(1.08);
        }

        .role-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 12px;
            background: rgba(139, 127, 218, 0.12);
            border: 1px solid rgba(139, 127, 218, 0.28);
            border-radius: 9999px;
            font-size: 12px;
            font-weight: 600;
            color: #8b7fda;
            letter-spacing: 0.3px;
        }

        body.canvas-light .role-pill {
            background: rgba(91, 70, 193, 0.08);
            border-color: rgba(91, 70, 193, 0.2);
            color: #5b46c1;
        }

        body.canvas-light .btn-ghost-on-dark {
            background: rgba(0,0,0,0.05) !important;
            color: #444 !important;
            border: 1px solid rgba(0,0,0,0.12) !important;
        }

        body.canvas-light .btn-ghost-on-dark:hover {
            background: rgba(0,0,0,0.08) !important;
        }

        body.canvas-light form button[type=submit] {
            background: rgba(220, 50, 100, 0.08) !important;
            color: #c0245e !important;
            border-color: rgba(220, 50, 100, 0.25) !important;
        }

        /* ── Back-to-top Button ──────────────────── */
        #back-to-top {
            position: fixed;
            bottom: 28px;
            right: 28px;
            z-index: 998;
            width: 46px;
            height: 46px;
            border-radius: 14px;
            border: 1px solid rgba(139, 127, 218, 0.35);
            background: rgba(15, 12, 30, 0.88);
            color: #c8f04e;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.35), 0 0 0 1px rgba(139,127,218,0.12);
            opacity: 0;
            transform: translateY(16px) scale(0.88);
            pointer-events: none;
            transition: opacity 0.3s cubic-bezier(0.16,1,0.3,1),
                        transform 0.3s cubic-bezier(0.16,1,0.3,1),
                        box-shadow 0.2s ease,
                        background 0.2s ease;
        }
        #back-to-top.btt-visible {
            opacity: 1;
            transform: translateY(0) scale(1);
            pointer-events: auto;
        }
        #back-to-top:hover {
            background: rgba(91, 70, 193, 0.85);
            border-color: rgba(200, 240, 78, 0.5);
            box-shadow: 0 0 20px rgba(200,240,78,0.25), 0 8px 32px rgba(0,0,0,0.4);
            transform: translateY(-3px) scale(1.06);
        }
        #back-to-top:active { transform: translateY(0) scale(0.96); }
        @@keyframes btt-bounce-anim {
            0%,100% { transform: translateY(0) scale(1); }
            40%      { transform: translateY(-8px) scale(1.08); }
            70%      { transform: translateY(-3px) scale(1.02); }
        }
        #back-to-top.btt-bounce { animation: btt-bounce-anim 0.5s ease; }
        body.canvas-light #back-to-top {
            background: rgba(255,255,255,0.92);
            border-color: rgba(91, 70, 193, 0.28);
            color: #5b46c1;
            box-shadow: 0 8px 24px rgba(0,0,0,0.12), 0 0 0 1px rgba(91,70,193,0.08);
        }
        body.canvas-light #back-to-top:hover {
            background: rgba(91,70,193,0.1);
        }

        /* ── Global Toast System ─────────────────── */
        #fap-toast-container {
            position: fixed;
            bottom: 88px;
            right: 24px;
            z-index: 9997;
            display: flex;
            flex-direction: column-reverse;
            gap: 10px;
            max-width: 360px;
            pointer-events: none;
        }
        .fap-toast {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            background: rgba(12, 9, 26, 0.92);
            border: 1px solid rgba(139,127,218,0.3);
            border-radius: 14px;
            padding: 14px 14px 10px 16px;
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            box-shadow: 0 16px 48px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.04);
            pointer-events: auto;
            opacity: 0;
            transform: translateX(20px) scale(0.96);
            transition: opacity 0.35s cubic-bezier(0.16,1,0.3,1),
                        transform 0.35s cubic-bezier(0.16,1,0.3,1);
            min-width: 280px;
        }
        .fap-toast--show {
            opacity: 1;
            transform: translateX(0) scale(1);
        }
        .fap-toast--hide {
            opacity: 0;
            transform: translateX(24px) scale(0.92);
        }
        .fap-toast__icon {
            font-size: 18px;
            line-height: 1;
            flex-shrink: 0;
            padding-top: 1px;
        }
        .fap-toast__body {
            flex: 1;
            min-width: 0;
        }
        .fap-toast__msg {
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 500;
            color: rgba(240,238,255,0.9);
            margin: 0 0 8px;
            line-height: 1.45;
        }
        .fap-toast__progress {
            height: 2px;
            background: rgba(255,255,255,0.08);
            border-radius: 99px;
            overflow: hidden;
        }
        @@keyframes fap-bar-shrink {
            from { width: 100%; }
            to   { width: 0%; }
        }
        .fap-toast__bar {
            height: 100%;
            border-radius: 99px;
            animation: fap-bar-shrink linear forwards;
        }
        .fap-toast__close {
            background: none;
            border: none;
            color: rgba(240,238,255,0.35);
            font-size: 16px;
            cursor: pointer;
            padding: 0 2px;
            line-height: 1;
            flex-shrink: 0;
            transition: color 0.15s ease;
            margin-top: -1px;
        }
        .fap-toast__close:hover { color: rgba(240,238,255,0.85); }
        /* Light mode toast */
        body.canvas-light .fap-toast {
            background: rgba(255,255,255,0.96);
            box-shadow: 0 8px 32px rgba(0,0,0,0.14);
        }
        body.canvas-light .fap-toast__msg { color: rgba(26,21,48,0.88); }
        body.canvas-light .fap-toast__close { color: rgba(26,21,48,0.3); }
        body.canvas-light .fap-toast__close:hover { color: rgba(26,21,48,0.7); }
    </style>
</body>
</html>
