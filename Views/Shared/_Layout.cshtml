<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FapWeb - Hệ thống quản lý học tập và điểm danh thông minh, cảnh báo thời gian thực qua SignalR WebSocket." />
    <title>@ViewData["Title"] - FapWeb</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FapWeb.styles.css" asp-append-version="true" />
</head>
@{
    var sessionUserId = Context.Session.GetString(AppSessionKeys.UserId);
    var sessionRoleName = Context.Session.GetString(AppSessionKeys.RoleName);
    var isLoggedIn = !string.IsNullOrWhiteSpace(sessionUserId);
    var isStaff = AppRoles.IsStaff(sessionRoleName);
    var isAdmin = AppRoles.IsAdmin(sessionRoleName);
    var canViewStudentAreas = AppRoles.IsParent(sessionRoleName) || AppRoles.IsStudent(sessionRoleName);

    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var isHomePage = string.Equals(controller, "Home", StringComparison.OrdinalIgnoreCase) &&
                     string.Equals(action, "Index", StringComparison.OrdinalIgnoreCase);

    var bodyClass = isHomePage ? "canvas-dark" : "canvas-light";
    var navbarClass = isHomePage ? "nav-bar-dark navbar-dark" : "nav-bar-light navbar-light";
    var btnThemeClass = isHomePage ? "btn-inverted" : "btn-primary";
}
<body class="@bodyClass">

    <!-- ⚡ Top Loading Bar -->
    <div id="top-loader" aria-hidden="true">
        <div id="top-loader-bar"></div>
        <div id="top-loader-glow"></div>
    </div>

    <header>
        <nav class="navbar navbar-expand-lg @navbarClass" id="main-navbar">
            <div class="container">
                <!-- Brand -->
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <div class="brand-icon">
                        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="28" height="28" rx="7" fill="url(#brand-grad)"/>
                            <path d="M7 14L11 10L14 13L17 9L21 14" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <circle cx="21" cy="14" r="2.5" fill="#c8f04e"/>
                            <defs>
                                <linearGradient id="brand-grad" x1="0" y1="0" x2="28" y2="28" gradientUnits="userSpaceOnUse">
                                    <stop stop-color="#5b46c1"/>
                                    <stop offset="1" stop-color="#8b7fda"/>
                                </linearGradient>
                            </defs>
                        </svg>
                    </div>
                    <span>FAPWEB</span>
                </a>

                <!-- Toggler -->
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Nav Links -->
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav flex-grow-1 ms-4 gap-1">
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-1" asp-area="" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-grid-1x2" style="font-size:13px;"></i> Dashboard
                            </a>
                        </li>
                        @if (isLoggedIn)
                        {
                            @if (isStaff)
                            {
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="ClassManagement" asp-action="Index">
                                        <i class="bi bi-building" style="font-size:13px;"></i> Classes
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="ScheduleManagement" asp-action="Index">
                                        <i class="bi bi-calendar3" style="font-size:13px;"></i> Schedule
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Attendance" asp-action="Index">
                                        <i class="bi bi-check2-square" style="font-size:13px;"></i> Attendance
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Tuition" asp-action="Index">
                                        <i class="bi bi-credit-card" style="font-size:13px;"></i> Tuition
                                    </a>
                                </li>
                            }

                            @if (isAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Transaction" asp-action="Index">
                                        <i class="bi bi-arrow-left-right" style="font-size:13px;"></i> Transactions
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="User" asp-action="Index">
                                        <i class="bi bi-people" style="font-size:13px;"></i> Users
                                    </a>
                                </li>
                            }

                            @if (canViewStudentAreas || isStaff)
                            {
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Notification" asp-action="Index">
                                        <i class="bi bi-bell" style="font-size:13px;"></i> Notifications
                                    </a>
                                </li>
                            }

                            @if (canViewStudentAreas)
                            {
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Attendance" asp-action="History">
                                        <i class="bi bi-clock-history" style="font-size:13px;"></i> Attendance History
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Tuition" asp-action="History">
                                        <i class="bi bi-receipt" style="font-size:13px;"></i> Payment History
                                    </a>
                                </li>
                            }

                            @if (!AppRoles.IsStaff(sessionRoleName))
                            {
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-controller="Transaction" asp-action="MyHistory">
                                        <i class="bi bi-wallet2" style="font-size:13px;"></i> My Transactions
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <!-- Auth Actions -->
                    <div class="d-flex align-items-center gap-2 ms-auto">
                        @if (isLoggedIn)
                        {
                            <!-- Role pill -->
                            <div class="role-pill">
                                <i class="bi bi-person-circle"></i>
                                <span>@sessionRoleName</span>
                            </div>
                            <a class="btn btn-sm btn-ghost-on-dark" style="padding:7px 14px; font-size:13px;" asp-controller="Auth" asp-action="ChangePassword">
                                <i class="bi bi-key me-1"></i>Password
                            </a>
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm" style="padding:7px 14px; font-size:13px; background:rgba(255,110,176,0.12); color:#ff6eb0; border:1px solid rgba(255,110,176,0.3); border-radius:10px;">
                                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                                </button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-sm @btnThemeClass" style="padding:8px 20px; font-size:14px;" asp-controller="Auth" asp-action="Login">
                                <i class="bi bi-lightning-charge-fill me-1"></i>Đăng nhập
                            </a>
                        }

                        <!-- Theme Toggle Button -->
                        <button id="theme-toggle-btn" title="Chuyển đổi giao diện" aria-label="Toggle theme">
                            <i class="bi bi-moon-stars-fill" id="theme-icon"></i>
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container py-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <!-- Squiggly Divider -->
    <div class="container-fluid px-0">
        <svg class="squiggly-divider" viewBox="0 0 1440 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 14C80 14 160 4 240 4C320 4 400 24 480 24C560 24 640 4 720 4C800 4 880 24 960 24C1040 24 1120 4 1200 4C1280 4 1360 14 1440 14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4 text-center text-md-start mb-3 mb-md-0">
                    <a asp-controller="Home" asp-action="Index" class="d-inline-flex align-items-center gap-2 text-decoration-none" style="opacity:0.7;">
                        <svg width="20" height="20" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="28" height="28" rx="7" fill="url(#footer-grad)"/>
                            <path d="M7 14L11 10L14 13L17 9L21 14" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <circle cx="21" cy="14" r="2.5" fill="#c8f04e"/>
                            <defs>
                                <linearGradient id="footer-grad" x1="0" y1="0" x2="28" y2="28" gradientUnits="userSpaceOnUse">
                                    <stop stop-color="#5b46c1"/>
                                    <stop offset="1" stop-color="#8b7fda"/>
                                </linearGradient>
                            </defs>
                        </svg>
                        <span style="font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:15px;">FAPWEB</span>
                    </a>
                    <p class="mt-2 mb-0" style="font-size:12px; opacity:0.5;">&copy; 2026 FapWeb. All rights reserved.</p>
                </div>
                <div class="col-md-4 text-center mb-3 mb-md-0">
                    <div class="badge-live mx-auto" style="width:fit-content;">
                        SYSTEM ONLINE
                    </div>
                </div>
                <div class="col-md-4 text-center text-md-end">
                    <span style="font-family:'JetBrains Mono',monospace; font-size:11px; opacity:0.4;">
                        SignalR · PostgreSQL · ASP.NET Core
                    </span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ── Scroll Reveal ────────────────────────────────────
        const reveals = document.querySelectorAll('.reveal');
        const revObs = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.classList.add('visible');
                    revObs.unobserve(e.target);
                }
            });
        }, { threshold: 0.12 });
        reveals.forEach(el => revObs.observe(el));

        // ── Navbar scroll shadow ─────────────────────────────
        const navbar = document.getElementById('main-navbar');
        if (navbar) {
            window.addEventListener('scroll', () => {
                navbar.style.boxShadow = window.scrollY > 20
                    ? '0 4px 30px rgba(0,0,0,0.4)'
                    : '';
            }, { passive: true });
        }

        // ── TOP LOADING BAR ──────────────────────────────────
        const Loader = {
            bar: document.getElementById('top-loader-bar'),
            wrap: document.getElementById('top-loader'),
            glow: document.getElementById('top-loader-glow'),
            timer: null,
            pct: 0,

            start() {
                this.pct = 0;
                this.wrap.style.opacity = '1';
                this.set(20);
                clearInterval(this.timer);
                this.timer = setInterval(() => {
                    if (this.pct < 85) this.set(this.pct + Math.random() * 8);
                }, 400);
            },

            set(p) {
                this.pct = Math.min(p, 99);
                this.bar.style.width = this.pct + '%';
                this.glow.style.left = this.pct + '%';
            },

            done() {
                clearInterval(this.timer);
                this.set(100);
                setTimeout(() => {
                    this.wrap.style.opacity = '0';
                    setTimeout(() => this.bar.style.width = '0', 400);
                }, 250);
            }
        };

        // Trigger on all internal link clicks
        document.addEventListener('click', function(e) {
            const a = e.target.closest('a[href]');
            if (!a) return;
            const href = a.getAttribute('href');
            if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('javascript:')) return;
            if (a.target === '_blank') return;
            try {
                const url = new URL(href, location.href);
                if (url.origin !== location.origin) return;
            } catch { return; }
            Loader.start();
        });

        // Trigger on form submits
        document.addEventListener('submit', function() {
            Loader.start();
        });

        // Complete when page finishes loading
        window.addEventListener('load', () => Loader.done());
        document.addEventListener('DOMContentLoaded', () => {
            // Immediate page load done signal
            if (document.readyState === 'complete') Loader.done();
        });

        // ── DARK / LIGHT MODE TOGGLE ─────────────────────────
        const ThemeToggle = {
            btn: document.getElementById('theme-toggle-btn'),
            icon: document.getElementById('theme-icon'),
            body: document.body,
            navbar: document.getElementById('main-navbar'),

            // Detect current mode from body class
            isDark() {
                return this.body.classList.contains('canvas-dark');
            },

            // Get saved preference; undefined = follow current server-rendered class
            getSaved() {
                return localStorage.getItem('fap-theme');
            },

            applyTheme(dark) {
                if (dark) {
                    this.body.classList.remove('canvas-light');
                    this.body.classList.add('canvas-dark');
                    if (this.navbar) {
                        this.navbar.classList.remove('nav-bar-light', 'navbar-light');
                        this.navbar.classList.add('nav-bar-dark', 'navbar-dark');
                    }
                    this.icon.className = 'bi bi-sun-fill';
                    this.btn.title = 'Chuyển sang sáng';
                } else {
                    this.body.classList.remove('canvas-dark');
                    this.body.classList.add('canvas-light');
                    if (this.navbar) {
                        this.navbar.classList.remove('nav-bar-dark', 'navbar-dark');
                        this.navbar.classList.add('nav-bar-light', 'navbar-light');
                    }
                    this.icon.className = 'bi bi-moon-stars-fill';
                    this.btn.title = 'Chuyển sang tối';
                }
            },

            init() {
                if (!this.btn) return;
                const saved = this.getSaved();
                if (saved) {
                    this.applyTheme(saved === 'dark');
                } else {
                    // Sync icon with server-rendered class
                    this.icon.className = this.isDark() ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
                    this.btn.title = this.isDark() ? 'Chuyển sang sáng' : 'Chuyển sang tối';
                }

                this.btn.addEventListener('click', () => {
                    const nowDark = !this.isDark();
                    this.applyTheme(nowDark);
                    localStorage.setItem('fap-theme', nowDark ? 'dark' : 'light');
                });
            }
        };

        ThemeToggle.init();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <style>
        /* ── Top Loading Bar ─────────────────────── */
        #top-loader {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: 3px;
            z-index: 9999;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        #top-loader-bar {
            position: absolute;
            top: 0; left: 0;
            height: 100%;
            width: 0;
            background: linear-gradient(90deg, #5b46c1, #c8f04e, #ff6eb0);
            border-radius: 0 3px 3px 0;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
            box-shadow: 0 0 12px rgba(200, 240, 78, 0.6);
        }
        #top-loader-glow {
            position: absolute;
            top: -2px;
            width: 80px;
            height: 7px;
            border-radius: 50%;
            background: rgba(200, 240, 78, 0.7);
            filter: blur(6px);
            transform: translateX(-50%);
            transition: left 0.3s ease;
        }

        /* ── Theme Toggle Button ─────────────────── */
        #theme-toggle-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1px solid rgba(139, 127, 218, 0.28);
            background: rgba(139, 127, 218, 0.1);
            color: #8b7fda;
            cursor: pointer;
            font-size: 15px;
            transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
            flex-shrink: 0;
        }
        #theme-toggle-btn:hover {
            background: rgba(139, 127, 218, 0.2);
            border-color: rgba(139, 127, 218, 0.5);
            transform: rotate(20deg) scale(1.08);
            color: #c8f04e;
        }
        body.canvas-light #theme-toggle-btn {
            background: rgba(91, 70, 193, 0.06);
            border-color: rgba(91, 70, 193, 0.18);
            color: #5b46c1;
        }
        body.canvas-light #theme-toggle-btn:hover {
            background: rgba(91, 70, 193, 0.12);
        }

        /* ── Brand icon ─────────────────────────── */
        .brand-icon {
            transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .navbar-brand:hover .brand-icon {
            transform: rotate(-8deg) scale(1.08);
        }

        .role-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 12px;
            background: rgba(139, 127, 218, 0.12);
            border: 1px solid rgba(139, 127, 218, 0.28);
            border-radius: 9999px;
            font-size: 12px;
            font-weight: 600;
            color: #8b7fda;
            letter-spacing: 0.3px;
        }

        body.canvas-light .role-pill {
            background: rgba(91, 70, 193, 0.08);
            border-color: rgba(91, 70, 193, 0.2);
            color: #5b46c1;
        }

        body.canvas-light .btn-ghost-on-dark {
            background: rgba(0,0,0,0.05) !important;
            color: #444 !important;
            border: 1px solid rgba(0,0,0,0.12) !important;
        }

        body.canvas-light .btn-ghost-on-dark:hover {
            background: rgba(0,0,0,0.08) !important;
        }

        body.canvas-light form button[type=submit] {
            background: rgba(220, 50, 100, 0.08) !important;
            color: #c0245e !important;
            border-color: rgba(220, 50, 100, 0.25) !important;
        }
    </style>
</body>
</html>
