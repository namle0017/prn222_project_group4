@model IEnumerable<FapWeb.Models.Dtos.NotificationDtos.NotificationResponseDto>

@{
    ViewData["Title"] = "Notifications";
    var notifications = Model.ToList();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">@ViewData["Title"]</h2>
        <span class="badge bg-primary fs-6">Total: @notifications.Count</span>
    </div>

    @if (!notifications.Any())
    {
        <div class="alert alert-info">
            You have no notifications yet.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Content</th>
                        <th>Created At</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in notifications)
                    {
                        var shortContent = item.Content.Length > 80
                            ? item.Content[..80] + "..."
                            : item.Content;

                        <tr>
                            <td>@item.Title</td>
                            <td>@shortContent</td>
                            <td>@(item.CreatedAt.HasValue ? item.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "—")</td>
                            <td>
                                <span class="badge @(item.IsRead ? "bg-secondary" : "bg-warning text-dark")">
                                    @(item.IsRead ? "Read" : "Unread")
                                </span>
                            </td>
                            <td class="text-end">
                                <a asp-controller="Notification"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    View Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
