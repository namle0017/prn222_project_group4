@model FapWeb.Models.Dtos.ScheduleManagementDtos.ClassScheduleViewDto

@{
    ViewData["Title"] = "Lịch học của lớp";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">@Model.ClassName</h2>
            <div class="text-muted">Giáo viên: @(string.IsNullOrWhiteSpace(Model.TeacherName) ? "Chưa phân công" : Model.TeacherName)</div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Create" asp-route-classId="@Model.ClassId" class="btn btn-primary">Thêm lịch học</a>
            <a asp-controller="ClassManagement" asp-action="Details" asp-route-id="@Model.ClassId" class="btn btn-outline-secondary">Về lớp học</a>
        </div>
    </div>

    @if (!Model.Schedules.Any())
    {
        <div class="alert alert-info shadow-sm">Chưa có lịch học cho lớp này.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Ngày</th>
                        <th>Thời gian</th>
                        <th>Chủ đề</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Schedules)
                    {
                        <tr>
                            <td>@item.ScheduleDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.StartTime - @item.EndTime</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Topic) ? "Không có" : item.Topic)</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.ScheduleId" class="btn btn-sm btn-outline-secondary">Sửa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
