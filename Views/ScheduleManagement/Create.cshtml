@model FapWeb.Models.Dtos.ScheduleManagementDtos.ScheduleFormDto

@{
    ViewData["Title"] = "Create Schedule";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">@ViewData["Title"]</h2>
                <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="ClassId" class="form-label">Class</label>
                        <select asp-for="ClassId" class="form-select">
                            <option value="">Select class</option>
                            @foreach (var item in Model.ClassOptions)
                            {
                                <option value="@item.Value" selected="@(Model.ClassId.ToString() == item.Value)">@item.Label</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ScheduleDate" class="form-label"></label>
                        <input asp-for="ScheduleDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="StartTime" class="form-label"></label>
                        <input asp-for="StartTime" type="time" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndTime" class="form-label"></label>
                        <input asp-for="EndTime" type="time" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Topic" class="form-label"></label>
                        <input asp-for="Topic" class="form-control" />
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Create Schedule</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
