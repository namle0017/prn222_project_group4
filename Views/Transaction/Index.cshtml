@model List<FapWeb.Models.Dtos.TransactionHistoryDtos.TransactionHistoryResponseDto>

@{
    ViewData["Title"] = "Lịch sử giao dịch";
    int pageNumber = (int)(ViewBag.PageNumber ?? 1);
    int pageSize = (int)(ViewBag.PageSize ?? 10);
    string? searchTerm = ViewBag.SearchTerm as string;
}

<div class="container mt-4">
    <h2 class="mb-4">@ViewData["Title"]</h2>

    <form asp-action="Search" asp-controller="Transaction" method="get" class="row g-2 mb-4">
        <div class="col-md-8">
            <input type="text"
                   name="searchTerm"
                   value="@searchTerm"
                   class="form-control"
                   placeholder="Tìm theo tên học sinh hoặc phụ huynh..." />
        </div>
        <div class="col-md-2">
            <input type="hidden" name="pageNumber" value="1" />
            <input type="hidden" name="pageSize" value="@pageSize" />
            <button type="submit" class="btn btn-primary w-100">Tìm kiếm</button>
        </div>
        @if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            <div class="col-md-2">
                <a asp-action="Index" asp-controller="Transaction" class="btn btn-outline-secondary w-100">Xóa bộ lọc</a>
            </div>
        }
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Không có giao dịch nào.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Mã giao dịch</th>
                        <th>Loại thanh toán</th>
                        <th>Số tiền</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Cập nhật lần cuối</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var item = Model[i];
                        <tr>
                            <td>@((pageNumber - 1) * pageSize + i + 1)</td>
                            <td><code>@item.Id.ToString()[..8]...</code></td>
                            <td>@(item.TransactionType ?? "—")</td>
                            <td>@item.Amount.ToString("N0") ₫</td>
                            <td>
                                <span class="badge @(item.TransactionStatus == "Success" ? "bg-success" : item.TransactionStatus == "Pending" ? "bg-warning text-dark" : "bg-secondary")">
                                    @item.TransactionStatus
                                </span>
                            </td>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(item.UpdatedAt.HasValue ? item.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav aria-label="Phân trang">
            <ul class="pagination justify-content-center">
                <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="@(string.IsNullOrWhiteSpace(searchTerm) ? "Index" : "Search")"
                       asp-route-searchTerm="@searchTerm"
                       asp-route-pageNumber="@(pageNumber - 1)"
                       asp-route-pageSize="@pageSize">
                        &laquo; Trước
                    </a>
                </li>
                <li class="page-item active">
                    <span class="page-link">Trang @pageNumber</span>
                </li>
                <li class="page-item @(Model.Count < pageSize ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="@(string.IsNullOrWhiteSpace(searchTerm) ? "Index" : "Search")"
                       asp-route-searchTerm="@searchTerm"
                       asp-route-pageNumber="@(pageNumber + 1)"
                       asp-route-pageSize="@pageSize">
                        Tiếp &raquo;
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>
