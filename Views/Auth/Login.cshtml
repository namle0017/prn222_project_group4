@model FapWeb.Models.Dtos.LoginDtos.LoginRequestDto

@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập hệ thống";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FAP Portal</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- CSS Icons & UI Library -->
    <link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="/css/site.css" />
    
    <style>
        :root {
            --primary-glow: #6366f1;   /* Indigo */
            --secondary-glow: #a855f7; /* Purple */
            --accent-lime: #c8f04e;    /* Lime */
            --bg-dark: #06040d;        /* Deep space violet base */
            --glass-bg: rgba(14, 10, 27, 0.6);
            --glass-border: rgba(255, 255, 255, 0.07);
            --text-muted: rgba(255, 255, 255, 0.45);
        }

        * {
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-dark);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #ffffff;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
            overflow-x: hidden;
            position: relative;
        }

        /* Interactive Particle Background */
        #particleCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }

        /* Ambient Glow Blobs */
        .ambient-glow {
            position: fixed;
            border-radius: 50%;
            filter: blur(140px);
            z-index: 2;
            pointer-events: none;
            opacity: 0.35;
            will-change: transform;
        }

        .glow-1 {
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, var(--primary-glow) 0%, rgba(99, 102, 241, 0) 70%);
            top: -100px;
            left: -100px;
            animation: pulse-glow-1 15s infinite alternate ease-in-out;
        }

        .glow-2 {
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, var(--secondary-glow) 0%, rgba(168, 85, 247, 0) 70%);
            bottom: -150px;
            right: -100px;
            animation: pulse-glow-2 18s infinite alternate ease-in-out;
        }

        @@keyframes pulse-glow-1 {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(100px, 60px) scale(1.15); }
        }

        @@keyframes pulse-glow-2 {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(-80px, -70px) scale(0.95); }
        }

        /* Grid Overlay */
        .background-overlay {
            position: fixed;
            inset: 0;
            background-image: 
                radial-gradient(rgba(255, 255, 255, 0.02) 1.5px, transparent 1.5px);
            background-size: 32px 32px;
            z-index: 3;
            pointer-events: none;
            opacity: 0.8;
        }

        /* Premium Glassmorphic Container */
        .login-card {
            width: 1000px;
            max-width: 100%;
            min-height: 620px;
            background: var(--glass-bg);
            backdrop-filter: blur(25px) saturate(190%);
            -webkit-backdrop-filter: blur(25px) saturate(190%);
            border: 1px solid var(--glass-border);
            border-radius: 32px;
            box-shadow: 0 40px 90px rgba(0, 0, 0, 0.7), 
                        inset 0 1px 0 rgba(255, 255, 255, 0.08);
            display: flex;
            overflow: hidden;
            position: relative;
            z-index: 10;
            transform-style: preserve-3d;
            will-change: transform;
            transition: box-shadow 0.3s ease;
        }

        /* Glossy shine reflection layer */
        .card-shine {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle 250px at 0% 0%, rgba(255, 255, 255, 0.08), transparent 80%);
            pointer-events: none;
            z-index: 11;
        }

        /* Brand Panel (Left) */
        .brand-panel {
            flex: 1;
            padding: 56px;
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.12) 0%, rgba(200, 240, 78, 0.04) 100%);
            border-right: 1px solid rgba(255, 255, 255, 0.06);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            z-index: 12;
        }

        .brand-logo-section {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .brand-logo-glow {
            filter: drop-shadow(0 0 16px rgba(99, 102, 241, 0.6));
            animation: rotate-subtle 25s infinite linear;
        }

        @@keyframes rotate-subtle {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700;
            font-size: 28px;
            letter-spacing: -0.5px;
            background: linear-gradient(90deg, #ffffff 0%, rgba(255, 255, 255, 0.8) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .system-status {
            display: inline-flex;
            align-items: center;
            background: rgba(200, 240, 78, 0.07);
            border: 1px solid rgba(200, 240, 78, 0.18);
            color: #c2ef4e;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            padding: 5px 14px;
            border-radius: 99px;
            letter-spacing: 0.7px;
            box-shadow: 0 0 10px rgba(200, 240, 78, 0.05);
        }

        .status-dot {
            width: 7px;
            height: 7px;
            background-color: #c2ef4e;
            border-radius: 50%;
            margin-right: 8px;
            animation: pulse-dot 1.8s infinite;
            box-shadow: 0 0 8px #c2ef4e;
        }

        @@keyframes pulse-dot {
            0% { opacity: 0.4; transform: scale(0.9); }
            50% { opacity: 1; transform: scale(1.2); }
            100% { opacity: 0.4; transform: scale(0.9); }
        }

        .brand-mid-content {
            margin: 48px 0;
        }

        .brand-headline {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700;
            font-size: 34px;
            line-height: 1.25;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #ffffff 20%, #c8f04e 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.5px;
        }

        .brand-description {
            color: var(--text-muted);
            font-size: 15px;
            line-height: 1.65;
            margin-bottom: 32px;
        }

        .features-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 14px;
            font-size: 14.5px;
            color: rgba(255, 255, 255, 0.85);
            transition: transform 0.3s ease, color 0.3s ease;
        }

        .feature-item:hover {
            transform: translateX(6px);
            color: #ffffff;
        }

        .feature-icon-wrapper {
            width: 36px;
            height: 36px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #c8f04e;
            font-size: 15px;
            transition: all 0.3s ease;
        }

        .feature-item:hover .feature-icon-wrapper {
            background: rgba(200, 240, 78, 0.12);
            border-color: rgba(200, 240, 78, 0.4);
            box-shadow: 0 0 12px rgba(200, 240, 78, 0.25);
            color: #ffffff;
        }

        .brand-footer {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.3);
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            padding-top: 24px;
            display: flex;
            justify-content: space-between;
        }

        /* Form Panel (Right) */
        .form-panel {
            flex: 1.2;
            padding: 56px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            z-index: 12;
        }

        .form-header {
            margin-bottom: 36px;
        }

        .form-title {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700;
            font-size: 30px;
            letter-spacing: -0.5px;
            margin-bottom: 10px;
            background: linear-gradient(135deg, #ffffff 60%, rgba(255, 255, 255, 0.7) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .form-subtitle {
            color: var(--text-muted);
            font-size: 14.5px;
        }

        /* Custom Input Groups with Gradient Border Focus */
        .input-group-custom {
            position: relative;
            margin-bottom: 24px;
        }

        .input-icon {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255, 255, 255, 0.3);
            font-size: 18px;
            transition: all 0.3s ease;
            z-index: 2;
        }

        .custom-input {
            width: 100%;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 14px;
            padding: 18px 20px 18px 50px;
            color: #ffffff;
            font-size: 15px;
            outline: none;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .custom-input:focus {
            background: linear-gradient(#0e0a1b, #0e0a1b) padding-box,
                        linear-gradient(135deg, var(--primary-glow) 0%, var(--accent-lime) 100%) border-box;
            border: 1px solid transparent;
            box-shadow: 0 0 20px rgba(99, 102, 241, 0.2), 0 0 0 4px rgba(99, 102, 241, 0.08);
        }

        .custom-input:focus ~ .input-icon {
            color: var(--primary-glow);
            transform: translateY(-50%) scale(1.1);
        }

        .custom-label {
            position: absolute;
            left: 50px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255, 255, 255, 0.4);
            pointer-events: none;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            font-size: 15px;
        }

        /* Input field animations for floating labels */
        .custom-input:focus ~ .custom-label,
        .custom-input:not(:placeholder-shown) ~ .custom-label {
            top: 0;
            transform: translateY(-50%) scale(0.85);
            left: 18px;
            background: #0d091b; /* Solid matching container base for crisp look */
            padding: 2px 8px;
            color: #818cf8;
            border-radius: 4px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* Eye toggle for password */
        .eye-toggle-btn {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            background: transparent;
            border: none;
            color: rgba(255, 255, 255, 0.4);
            cursor: pointer;
            z-index: 3;
            transition: color 0.3s ease, transform 0.2s ease;
            padding: 6px;
        }

        .eye-toggle-btn:hover {
            color: #ffffff;
            transform: translateY(-50%) scale(1.1);
        }

        /* Buttons with Metallic Shimmer Sweep Effect */
        .btn-submit-premium {
            background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            color: #ffffff;
            border: none;
            border-radius: 14px;
            padding: 18px;
            font-weight: 700;
            font-size: 16px;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 8px 24px rgba(99, 102, 241, 0.35);
            position: relative;
            overflow: hidden;
        }

        .btn-submit-premium::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -60%;
            width: 30%;
            height: 200%;
            background: linear-gradient(
                to right,
                rgba(255, 255, 255, 0) 0%,
                rgba(255, 255, 255, 0.35) 50%,
                rgba(255, 255, 255, 0) 100%
            );
            transform: rotate(25deg);
            animation: shimmer 3.5s infinite linear;
            pointer-events: none;
        }

        @@keyframes shimmer {
            0% { left: -60%; }
            100% { left: 140%; }
        }

        .btn-submit-premium:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(99, 102, 241, 0.5), 0 0 15px rgba(168, 85, 247, 0.25);
            background: linear-gradient(135deg, #4f46e5 0%, #9333ea 100%);
        }

        .btn-submit-premium:active {
            transform: translateY(-1px);
        }

        /* ASP.NET validation messages */
        .validation-summary-errors {
            background: rgba(239, 68, 68, 0.08) !important;
            border: 1px solid rgba(239, 68, 68, 0.2) !important;
            color: #fc8181 !important;
            border-radius: 12px;
            padding: 14px 18px;
            margin-bottom: 24px;
            font-size: 13.5px;
            list-style: none;
            box-shadow: 0 0 15px rgba(239, 68, 68, 0.05);
        }

        .validation-summary-errors ul {
            padding-left: 16px;
            margin: 0;
        }

        .validation-summary-valid {
            display: none !important;
        }

        .field-validation-error {
            color: #fc8181;
            font-size: 12.5px;
            margin-top: 6px;
            display: block;
        }

        /* Developer Quick Access Panel */
        .quick-access-box {
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            padding-top: 24px;
            margin-top: 16px;
        }

        .btn-quick-toggle {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.06);
            color: rgba(255, 255, 255, 0.6);
            border-radius: 10px;
            padding: 10px 18px;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-quick-toggle:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #ffffff;
            border-color: rgba(99, 102, 241, 0.35);
        }

        .quick-access-body {
            max-height: 350px;
            overflow: hidden;
            transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
            opacity: 1;
        }

        .quick-access-body.collapsed {
            max-height: 0;
            opacity: 0;
            margin-top: 0 !important;
        }

        .demo-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            padding: 12px 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            text-align: left;
            position: relative;
            overflow: hidden;
        }

        .demo-card:hover {
            background: rgba(99, 102, 241, 0.08);
            border-color: rgba(99, 102, 241, 0.35);
            transform: translateY(-2px);
        }

        .demo-role {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 4px;
            display: inline-flex;
            padding: 3px 8px;
            border-radius: 5px;
            letter-spacing: 0.5px;
        }

        .demo-role.admin { background: rgba(239, 68, 68, 0.12); color: #f87171; }
        .demo-role.teacher { background: rgba(59, 130, 246, 0.12); color: #60a5fa; }
        .demo-role.student { background: rgba(16, 185, 129, 0.12); color: #34d399; }
        .demo-role.parent { background: rgba(245, 158, 11, 0.12); color: #fbbf24; }

        .demo-phone {
            font-size: 13.5px;
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 2px;
        }

        .demo-pass {
            font-size: 11px;
            color: var(--text-muted);
        }

        .quick-note {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.3);
        }

        /* Toast notifications */
        .quick-toast {
            position: fixed;
            bottom: 32px;
            right: 32px;
            background: rgba(14, 10, 27, 0.95);
            border: 1px solid rgba(99, 102, 241, 0.4);
            padding: 14px 28px;
            border-radius: 14px;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.7);
            z-index: 1000;
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            pointer-events: none;
            display: flex;
            align-items: center;
        }

        .quick-toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-content {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14.5px;
        }

        /* Mobile adjustments */
        @@media (max-width: 900px) {
            .login-card {
                flex-direction: column;
                max-width: 480px;
                min-height: auto;
                border-radius: 24px;
            }

            .brand-panel {
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.06);
                padding: 40px 28px;
            }

            .brand-logo-section {
                justify-content: center;
            }

            .brand-mid-content {
                display: none; /* Hide features on small screens */
            }

            .brand-footer {
                display: none;
            }

            .form-panel {
                padding: 40px 28px;
            }
        }
    </style>
</head>
<body>

    <!-- Interactive canvas for floating particles system -->
    <canvas id="particleCanvas"></canvas>

    <!-- Ambient glowing backgrounds -->
    <div class="ambient-glow glow-1"></div>
    <div class="ambient-glow glow-2"></div>
    <div class="background-overlay"></div>

    <!-- Main Card Container -->
    <div class="login-card">
        <!-- 3D Shine effect overlay -->
        <div class="card-shine"></div>
        
        <!-- Left Side: Brand Panel -->
        <div class="brand-panel">
            <div class="d-flex justify-content-between align-items-center">
                <div class="brand-logo-section">
                    <svg class="brand-logo-glow" width="38" height="38" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="logoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#6366f1" />
                                <stop offset="100%" stop-color="#c8f04e" />
                            </linearGradient>
                            <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
                                <feGaussianBlur stdDeviation="4" result="blur" />
                                <feComposite in="SourceGraphic" in2="blur" operator="over" />
                            </filter>
                        </defs>
                        <path d="M32 8L56 22L32 36L8 22L32 8Z" fill="url(#logoGrad)" filter="url(#glow)" />
                        <path d="M16 28V42C16 48 24 52 32 52C40 52 48 48 48 42V28L32 37L16 28Z" fill="url(#logoGrad)" opacity="0.85" />
                    </svg>
                    <span class="brand-name">FAP Portal</span>
                </div>
                <div class="system-status">
                    <span class="status-dot"></span> Online
                </div>
            </div>

            <div class="brand-mid-content">
                <h1 class="brand-headline">Hệ thống quản lý học tập thế hệ mới</h1>
                <p class="brand-description">Trải nghiệm cổng thông tin học thuật trực quan, nhanh chóng và an toàn dành cho sinh viên, giáo viên và phụ huynh FPT.</p>
                
                <ul class="features-list">
                    <li class="feature-item">
                        <div class="feature-icon-wrapper">
                            <i class="bi bi-calendar3"></i>
                        </div>
                        <span>Quản lý thời khóa biểu trực quan</span>
                    </li>
                    <li class="feature-item">
                        <div class="feature-icon-wrapper">
                            <i class="bi bi-person-check"></i>
                        </div>
                        <span>Theo dõi chuyên cần &amp; điểm danh thực tế</span>
                    </li>
                    <li class="feature-item">
                        <div class="feature-icon-wrapper">
                            <i class="bi bi-credit-card"></i>
                        </div>
                        <span>Cổng học phí thanh toán tự động SePay</span>
                    </li>
                    <li class="feature-item">
                        <div class="feature-icon-wrapper">
                            <i class="bi bi-bell"></i>
                        </div>
                        <span>Hệ thống thông báo tức thời</span>
                    </li>
                </ul>
            </div>

            <div class="brand-footer">
                <span>PRN222 Project - Group 4</span>
                <span>v2.0.26</span>
            </div>
        </div>

        <!-- Right Side: Form Panel -->
        <div class="form-panel">
            <div class="form-header">
                <h2 class="form-title">Đăng Nhập</h2>
                <p class="form-subtitle">Nhập số điện thoại đã đăng ký để kết nối vào hệ thống.</p>
            </div>

            <form asp-action="Login" asp-controller="Auth" method="post" autocomplete="off" id="loginForm">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <!-- Phone Input Group -->
                <div class="input-group-custom">
                    <i class="bi bi-telephone input-icon"></i>
                    <input asp-for="UserPhoneNumber" class="custom-input" placeholder=" " id="UserPhoneNumber" required />
                    <label asp-for="UserPhoneNumber" class="custom-label">Số điện thoại</label>
                    <span asp-validation-for="UserPhoneNumber" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Password Input Group -->
                <div class="input-group-custom">
                    <i class="bi bi-lock input-icon"></i>
                    <input asp-for="UserPassword" type="password" class="custom-input" placeholder=" " id="UserPassword" required />
                    <label asp-for="UserPassword" class="custom-label">Mật khẩu</label>
                    <button type="button" class="eye-toggle-btn" onclick="togglePassword()" aria-label="Toggle password visibility">
                        <i class="bi bi-eye" id="togglePasswordIcon"></i>
                    </button>
                    <span asp-validation-for="UserPassword" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Actions Button -->
                <div class="d-flex flex-column gap-3 mt-4">
                    <button type="submit" class="btn-submit-premium w-100" id="submitBtn">
                        KẾT NỐI HỆ THỐNG <i class="bi bi-box-arrow-in-right ms-2"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Quick Toast Notification -->
    <div class="quick-toast" id="quickToast">
        <div class="toast-content">
            <i class="bi bi-check-circle-fill text-success fs-5"></i>
            <span class="toast-text" id="toastMessage"></span>
        </div>
    </div>

    <!-- Scripts -->
    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script>
        // Password visibility toggle
        function togglePassword() {
            const passwordInput = document.getElementById('UserPassword');
            const toggleIcon = document.getElementById('togglePasswordIcon');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('bi-eye');
                toggleIcon.classList.add('bi-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('bi-eye-slash');
                toggleIcon.classList.add('bi-eye');
            }
        }

        // Quick Access drawer toggle (kept for potential back-compat support)
        function toggleQuickAccess() {
            const body = document.getElementById('quickAccessBody');
            const chevron = document.getElementById('quickChevron');
            if (body && body.classList.contains('collapsed')) {
                body.classList.remove('collapsed');
                if (chevron) {
                    chevron.classList.remove('bi-chevron-down');
                    chevron.classList.add('bi-chevron-up');
                }
            } else if (body) {
                body.classList.add('collapsed');
                if (chevron) {
                    chevron.classList.remove('bi-chevron-up');
                    chevron.classList.add('bi-chevron-down');
                }
            }
        }

        // Autofill credentials
        function fillCredentials(phone, password, role) {
            const phoneInput = document.getElementById('UserPhoneNumber');
            const passInput = document.getElementById('UserPassword');
            
            if (phoneInput && passInput) {
                phoneInput.value = phone;
                passInput.value = password;
                
                // Dispatch events to trigger CSS floating label state & validation
                const event = new Event('input', { bubbles: true });
                phoneInput.dispatchEvent(event);
                passInput.dispatchEvent(event);

                const changeEvent = new Event('change', { bubbles: true });
                phoneInput.dispatchEvent(changeEvent);
                passInput.dispatchEvent(changeEvent);
                
                // Show toast message
                showToast(`Đã tự động điền tài khoản: ${role}`);
            }
        }

        // Toast display function
        function showToast(message) {
            const toast = document.getElementById('quickToast');
            const toastText = document.getElementById('toastMessage');
            if (toast && toastText) {
                toastText.textContent = message;
                
                toast.classList.add('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                }, 3000);
            }
        }

        // Form submit state handler
        $(document).ready(function() {
            const form = document.getElementById('loginForm');
            const btn = document.getElementById('submitBtn');
            
            if (form && btn) {
                form.addEventListener('submit', function(e) {
                    if ($(form).valid()) {
                        btn.disabled = true;
                        btn.innerHTML = '<i class="bi bi-arrow-repeat me-2" style="animation:spin 1s linear infinite;display:inline-block"></i> ĐANG KẾT NỐI...';
                        btn.style.opacity = '0.8';
                    }
                });
            }

            // Ensure floating labels remain floating if inputs contain autofilled data (e.g. by browser)
            const inputs = document.querySelectorAll('.custom-input');
            inputs.forEach(input => {
                // Initial check
                if (input.value.trim() !== '') {
                    input.placeholder = " "; // Force floating state
                }
                // Listener
                input.addEventListener('change', () => {
                    if (input.value.trim() !== '') {
                        input.placeholder = " ";
                    }
                });
            });
        });

        // Interactive Particle System
        (function() {
            const canvas = document.getElementById('particleCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            
            let particlesArray = [];
            let mouse = {
                x: null,
                y: null,
                radius: 120
            };
            
            window.addEventListener('mousemove', function(event) {
                mouse.x = event.clientX;
                mouse.y = event.clientY;
            });
            
            window.addEventListener('mouseout', function() {
                mouse.x = null;
                mouse.y = null;
            });
            
            class Particle {
                constructor(x, y, directionX, directionY, size, color) {
                    this.x = x;
                    this.y = y;
                    this.directionX = directionX;
                    this.directionY = directionY;
                    this.size = size;
                    this.color = color;
                }
                
                draw() {
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2, false);
                    ctx.fillStyle = this.color;
                    ctx.fill();
                }
                
                update() {
                    if (this.x > canvas.width || this.x < 0) {
                        this.directionX = -this.directionX;
                    }
                    if (this.y > canvas.height || this.y < 0) {
                        this.directionY = -this.directionY;
                    }
                    
                    // Mouse collision / repulsion
                    if (mouse.x !== null && mouse.y !== null) {
                        let dx = mouse.x - this.x;
                        let dy = mouse.y - this.y;
                        let distance = Math.sqrt(dx * dx + dy * dy);
                        if (distance < mouse.radius + this.size) {
                            if (mouse.x < this.x && this.x < canvas.width - this.size * 10) {
                                this.x += 1.5;
                            }
                            if (mouse.x > this.x && this.x > this.size * 10) {
                                this.x -= 1.5;
                            }
                            if (mouse.y < this.y && this.y < canvas.height - this.size * 10) {
                                this.y += 1.5;
                            }
                            if (mouse.y > this.y && this.y > this.size * 10) {
                                this.y -= 1.5;
                            }
                        }
                    }
                    
                    this.x += this.directionX;
                    this.y += this.directionY;
                    this.draw();
                }
            }
            
            function init() {
                particlesArray = [];
                let numberOfParticles = (canvas.width * canvas.height) / 10000;
                if (numberOfParticles > 120) numberOfParticles = 120;
                
                for (let i = 0; i < numberOfParticles; i++) {
                    let size = (Math.random() * 2) + 0.8;
                    let x = (Math.random() * ((canvas.width - size * 2) - (size * 2)) + size * 2);
                    let y = (Math.random() * ((canvas.height - size * 2) - (size * 2)) + size * 2);
                    let directionX = (Math.random() * 0.3) - 0.15;
                    let directionY = (Math.random() * 0.3) - 0.15;
                    let color = 'rgba(99, 102, 241, ' + (Math.random() * 0.2 + 0.15) + ')';
                    
                    particlesArray.push(new Particle(x, y, directionX, directionY, size, color));
                }
            }
            
            function connect() {
                let opacityValue = 1;
                for (let a = 0; a < particlesArray.length; a++) {
                    for (let b = a; b < particlesArray.length; b++) {
                        let dx = particlesArray[a].x - particlesArray[b].x;
                        let dy = particlesArray[a].y - particlesArray[b].y;
                        let distance = Math.sqrt(dx * dx + dy * dy);
                        
                        if (distance < 90) {
                            opacityValue = 1 - (distance / 90);
                            ctx.strokeStyle = 'rgba(99, 102, 241, ' + (opacityValue * 0.08) + ')';
                            ctx.lineWidth = 1;
                            ctx.beginPath();
                            ctx.moveTo(particlesArray[a].x, particlesArray[a].y);
                            ctx.lineTo(particlesArray[b].x, particlesArray[b].y);
                            ctx.stroke();
                        }
                    }
                }
            }
            
            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                for (let i = 0; i < particlesArray.length; i++) {
                    particlesArray[i].update();
                }
                connect();
                requestAnimationFrame(animate);
            }
            
            window.addEventListener('resize', function() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
                init();
            });
            
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            init();
            animate();
        })();

        // 3D Card Tilt & Shine Effect
        (function() {
            const card = document.querySelector('.login-card');
            const shine = document.querySelector('.card-shine');
            if (!card) return;
            
            card.addEventListener('mousemove', function(e) {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                const centerX = rect.width / 2;
                const centerY = rect.height / 2;
                
                const rotateX = ((centerY - y) / centerY) * 4; // Max 4 degrees tilt for subtle look
                const rotateY = ((x - centerX) / centerX) * 4;
                
                card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.005, 1.005, 1.005)`;
                
                if (shine) {
                    const pctX = (x / rect.width) * 100;
                    const pctY = (y / rect.height) * 100;
                    shine.style.background = `radial-gradient(circle 250px at ${pctX}% ${pctY}%, rgba(255, 255, 255, 0.1), transparent 85%)`;
                }
            });
            
            card.addEventListener('mouseleave', function() {
                card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
                card.style.transition = 'transform 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
                if (shine) {
                    shine.style.background = 'radial-gradient(circle 250px at 0% 0%, rgba(255, 255, 255, 0.08), transparent 80%)';
                    shine.style.transition = 'background 0.6s ease';
                }
            });
            
            card.addEventListener('mouseenter', function() {
                card.style.transition = 'none';
                if (shine) {
                    shine.style.transition = 'none';
                }
            });
        })();
    </script>
    <style>
        @@keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
    </style>
</body>
</html>
