@model FapWeb.Models.Dtos.LoginDtos.LoginRequestDto

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card p-4 border border-secondary" style="border-radius: var(--rounded-xl) !important; background-color: var(--colors-surface-canvas-light) !important;">
            <div class="card-body p-2">
                <!-- Sentry Console Form Header -->
                <div class="text-center mb-4">
                    <span class="badge bg-success mb-2">SECURE_GATEWAY_v1.0</span>
                    <h2 class="heading-md mb-2" style="font-family: var(--font-display); font-weight: 700; letter-spacing: -0.5px;">ĐĂNG NHẬP HỆ THỐNG</h2>
                    <span class="small text-muted d-block">Vui lòng kết nối bằng số điện thoại đăng ký</span>
                </div>

                <form asp-action="Login" asp-controller="Auth" method="post" autocomplete="off">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 mb-3" style="font-size: 14px;"></div>

                    <!-- Phone Number Input -->
                    <div class="mb-4">
                        <label asp-for="UserPhoneNumber" class="eyebrow d-block mb-2 text-uppercase" style="font-size: 12px; font-weight: 600; color: var(--colors-accent-violet-mid);">
                            [ PHONE_NUMBER ]
                        </label>
                        <input asp-for="UserPhoneNumber" class="form-control" placeholder="Nhập số điện thoại (e.g. 09xxxxxxxx)" />
                        <span asp-validation-for="UserPhoneNumber" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Password Input -->
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label asp-for="UserPassword" class="eyebrow text-uppercase" style="font-size: 12px; font-weight: 600; color: var(--colors-accent-violet-mid);">
                                [ ACC_PASSWORD ]
                            </label>
                        </div>
                        <input asp-for="UserPassword" type="password" class="form-control" placeholder="Nhập mật khẩu truy cập" />
                        <span asp-validation-for="UserPassword" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Primary Action Button -->
                    <button type="submit" class="btn btn-primary w-100 py-3 mt-2" style="font-weight: 700;">
                        KẾT NỐI HỆ THỐNG
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
