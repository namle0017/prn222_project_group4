# Copy file này thành .env rồi điền giá trị thật.
# Các biến này sẽ được docker-compose bơm vào container,
# ghi đè (hoặc thay thế) appsettings.json.

ConnectionStrings__DefaultConnection=Host=YOUR_DB_HOST;Database=postgres;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

SePay__UrlSePay=https://pgapi-sandbox.sepay.vn/v1/checkout/init
SePay__ApiKey=YOUR_SEPAY_API_KEY
SePay__MerchantId=YOUR_SEPAY_MERCHANT_ID
SePay__SecretKey=YOUR_SEPAY_SECRET_KEY
SePay__ReturnUrl=http://localhost:xxxx/api/payment/return
BaseCallbackUrl=http://localhost:xxxx