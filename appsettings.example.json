{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "BaseCallbackUrl": "YOUR_APP_BASE_URL",
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_DB_HOST;Database=postgres;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"
  },

  "SePay": {
    "UrlSePay": "https://pay-sandbox.sepay.vn/v1/checkout/init",
    "ApiKey": "YOUR_SEPAY_API_KEY",
    "MerchantId": "YOUR_SEPAY_MERCHANT_ID",
    "SecretKey": "YOUR_SEPAY_SECRET_KEY"
  }
}
