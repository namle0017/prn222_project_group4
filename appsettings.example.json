{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "BaseCallbackUrl": "YOUR_APP_BASE_URL",
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_DB_HOST;Database=postgres;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"
  },

  "SePay": {
    "UrlSePay": "https://pay-sandbox.sepay.vn/v1/checkout/init",
    "ApiKey": "YOUR_SEPAY_API_KEY",
    "MerchantId": "YOUR_SEPAY_MERCHANT_ID",
    "SecretKey": "YOUR_SEPAY_SECRET_KEY"
  },
  "MiMo": {
    "ApiBaseUrl": "https://api.xiaomimimo.com/v1/chat/completions",
    "Model": "mimo-v2.5",
    "ApiKey": "YOUR_MIMO_API_KEY",
    "RequestTimeoutSeconds": 20,
    "MaxQuestionLength": 500,
    "MaxCompletionTokens": 500,
    "MaxRequestsPerWindow": 10,
    "RateLimitWindowMinutes": 5
  },
  "DemoData": {
    "SeedOnStartup": false,
    "Password": "YOUR_DEMO_PASSWORD"
  }
}
